{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🔍 check",
            "type": "shell",
            "command": "cargo",
            "args": [
                "check"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🛠 build",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🚀 release",
            "type": "shell",
            "command": "cargo",
            "args": [
                "build",
                "--release"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "▶ run",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "⚡ run-release",
            "type": "shell",
            "command": "cargo",
            "args": [
                "run",
                "--release"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🧪 test",
            "type": "shell",
            "command": "cargo",
            "args": [
                "test"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🧹 lint",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clippy",
                "--",
                "-D",
                "warnings",
                "-W",
                "clippy::pedantic"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🎨 fmt",
            "type": "shell",
            "command": "cargo",
            "args": [
                "fmt"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🎨 fmt-check",
            "type": "shell",
            "command": "cargo",
            "args": [
                "fmt",
                "--",
                "--check"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "📚 doc",
            "type": "shell",
            "command": "cargo",
            "args": [
                "doc",
                "--no-deps",
                "--open"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "📊 coverage",
            "type": "shell",
            "command": "cargo",
            "args": [
                "tarpaulin",
                "--out",
                "html",
                "--output-dir",
                "target/coverage"
            ],
            "problemMatcher": [
                "$rustc"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "🧼 clean",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clean"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "♻ ci",
            "type": "shell",
            "command": "cargo",
            "args": [
                "fmt",
                "--",
                "--check"
            ],
            "dependsOrder": "sequence",
            "dependsOn": [
                "🧹 lint",
                "🧪 test"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}