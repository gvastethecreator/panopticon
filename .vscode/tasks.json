{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cargo",
            "command": "build",
            "label": "Panopticon: Build Debug",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cargo",
            "command": "build",
            "args": [
                "--release"
            ],
            "label": "Panopticon: Build Release",
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cargo",
            "command": "check",
            "label": "Panopticon: Check",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cargo",
            "command": "clippy",
            "args": [
                "--",
                "-D",
                "warnings"
            ],
            "label": "Panopticon: Clippy",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cargo",
            "command": "run",
            "label": "Panopticon: Run Debug",
            "problemMatcher": [
                "$rustc"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "type": "cargo",
            "command": "run",
            "args": [
                "--release"
            ],
            "label": "Panopticon: Run Release",
            "problemMatcher": [
                "$rustc"
            ],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}