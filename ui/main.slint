// ── Panopticon – Slint UI ─────────────────────────────────────
// Dark theme optimised for Windows 11 with warm amber accents.

import { CheckBox, ComboBox, LineEdit, ScrollView, GroupBox, Button,
         VerticalBox, HorizontalBox, TabWidget, Slider, SpinBox } from "std-widgets.slint";

// ── Theme colours ────────────────────────────────────────────

export global Theme {
    in-out property <color> bg:           #181513;
    in-out property <color> toolbar-bg:   #1a1814;
    in-out property <color> panel-bg:     #2A2522;
    in-out property <color> card-bg:      #1e1c1a;
    in-out property <color> border:       #3a3530;
    in-out property <color> accent:       #D29A5C;
    in-out property <color> accent-soft:  #5C4A38;
    in-out property <color> text:         #E6E2DE;
    in-out property <color> label:        #C8C1BA;
    in-out property <color> muted:        #8D867F;
    in-out property <color> hover-border: #D29A5C;
    in-out property <color> placeholder:  #141210;
    in-out property <color> footer-bg:    #1a1814;
    in-out property <color> surface:      #221E1C;
}

// ── Data structures ──────────────────────────────────────────

export struct ThumbnailData {
    x: float,
    y: float,
    width: float,
    height: float,
    title: string,
    app-label: string,
    is-hovered: bool,
    is-active: bool,
    accent-color: color,
    show-footer: bool,
    is-minimized: bool,
    icon: image,
    show-icon: bool,
}

/// A draggable separator between layout cells.
export struct ResizeHandleData {
    /// Position on the split axis (px).
    x: float,
    y: float,
    width: float,
    height: float,
    /// true = horizontal line → resize vertically.
    horizontal: bool,
    /// Index into the ratio array.
    index: int,
}

// ── Thumbnail card ───────────────────────────────────────────

component ThumbnailCard inherits Rectangle {
    in property <string> title;
    in property <string> app-label;
    in property <bool> is-hovered;
    in property <bool> is-active;
    in property <bool> show-footer: true;
    in property <color> accent-color: Theme.accent;
    in property <bool> is-minimized: false;
    in property <image> icon-image;
    in property <bool> show-icon: false;

    callback clicked();
    callback right-clicked(/* x */ float, /* y */ float);
    callback pointer-moved(/* x */ float, /* y */ float);

    background: Theme.card-bg;
    border-width: is-hovered || is-active ? 2px : 1px;
    border-color: is-active ? Theme.accent : (is-hovered ? Theme.hover-border : Theme.border);
    border-radius: 4px;
    clip: true;
    property <bool> has-icon: root.show-icon && root.icon-image.width > 0;
    property <length> footer-height: root.show-footer ? 34px : 0px;
    property <length> overlay-strip-height: root.has-icon && !root.is-minimized ? 28px : 0px;

    // Accent strip
    Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 3px;
        background: root.accent-color;
    }

    // DWM thumbnail area — intentionally empty/dark so the compositor
    // can overlay the live window preview on top.
    Rectangle {
        x: 1px;
        y: 3px + root.overlay-strip-height;
        width: parent.width - 2px;
        height: parent.height - 3px - root.overlay-strip-height - root.footer-height;
        background: Theme.placeholder;
    }

    // Minimized overlay: show app label + icon when window is minimized
    if root.is-minimized: Rectangle {
        x: 1px;
        y: 3px;
        width: parent.width - 2px;
        height: parent.height - 3px - root.footer-height;
        background: Theme.panel-bg;

        Rectangle {
            x: 10px;
            y: 10px;
            width: parent.width - 20px;
            height: parent.height - 20px;
            background: Theme.surface.with-alpha(0.42);
            border-width: 1px;
            border-color: Theme.border.with-alpha(0.85);
            border-radius: 10px;
        }

        VerticalLayout {
            alignment: center;
            spacing: 10px;
            padding: 16px;

            if root.icon-image.width > 0: Rectangle {
                width: min(60px, parent.width - 32px);
                height: self.width;
                border-radius: 12px;
                background: Theme.footer-bg.with-alpha(0.9);
                border-width: 1px;
                border-color: Theme.border.with-alpha(0.9);
                drop-shadow-blur: 10px;
                drop-shadow-color: #00000044;
                drop-shadow-offset-y: 2px;

                Image {
                    x: 6px;
                    y: 6px;
                    width: parent.width - 12px;
                    height: parent.height - 12px;
                    source: root.icon-image;
                    image-fit: contain;
                }
            }

            Text {
                text: root.app-label;
                color: Theme.label;
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                overflow: elide;
            }
            Text {
                text: "Minimized";
                color: Theme.muted.with-alpha(0.6);
                font-size: 10px;
                horizontal-alignment: center;
            }
        }
    }

    // App icon in a reserved top-right strip so it never fights with the DWM
    // thumbnail composition layer.
    if root.has-icon && !root.is-minimized: Rectangle {
        x: parent.width - 30px;
        y: 7px;
        width: 24px;
        height: 24px;
        background: Theme.footer-bg.with-alpha(0.88);
        border-width: 1px;
        border-color: (root.is-active ? Theme.accent : Theme.border).with-alpha(0.9);
        border-radius: 4px;
        drop-shadow-blur: 8px;
        drop-shadow-color: #00000033;
        drop-shadow-offset-y: 1px;

        Image {
            x: 2px;
            y: 2px;
            width: 20px;
            height: 20px;
            source: root.icon-image;
            image-fit: contain;
        }
    }

    // Footer with title + app label
    if root.show-footer: Rectangle {
        x: 0;
        y: parent.height - 34px;
        width: 100%;
        height: 34px;
        background: Theme.footer-bg;

        Text {
            x: 10px;
            y: 0;
            width: parent.width * 55% - 15px;
            height: 100%;
            text: root.title;
            color: Theme.label;
            vertical-alignment: center;
            font-size: 12px;
            overflow: elide;
        }

        Text {
            x: parent.width * 55%;
            y: 0;
            width: parent.width * 45% - 10px;
            height: 100%;
            text: root.app-label;
            color: Theme.muted;
            horizontal-alignment: right;
            vertical-alignment: center;
            font-size: 11px;
            overflow: elide;
        }
    }

    // Hover tooltip (shows title when footer is hidden)
    if root.is-hovered && !root.show-footer: Rectangle {
        x: 0;
        y: parent.height - 28px;
        width: 100%;
        height: 28px;
        background: Theme.footer-bg.with-alpha(0.92);

        Text {
            x: 10px;
            y: 0;
            width: parent.width - 20px;
            height: 100%;
            text: root.title + (root.app-label != "" ? ("  ·  " + root.app-label) : "");
            color: Theme.label;
            vertical-alignment: center;
            font-size: 12px;
            overflow: elide;
        }
    }

    // Hover tooltip (shows full title when footer IS shown but title is long)
    if root.is-hovered && root.show-footer: Rectangle {
        x: 0;
        y: parent.height - 34px - 24px;
        width: 100%;
        height: 24px;
        background: Theme.footer-bg.with-alpha(0.92);

        Text {
            x: 10px;
            y: 0;
            width: parent.width - 20px;
            height: 100%;
            text: root.title;
            color: Theme.text;
            vertical-alignment: center;
            font-size: 11px;
            overflow: elide;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
        pointer-event(event) => {
            if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                root.right-clicked(touch.mouse-x / 1px, touch.mouse-y / 1px);
            }
        }
        moved => {
            root.pointer-moved(touch.mouse-x / 1px, touch.mouse-y / 1px);
        }
    }
}

// ── Resize handle (draggable separator) ──────────────────────

component ResizeHandle inherits Rectangle {
    in property <bool> horizontal;
    in property <int> handle-index;
    in property <bool> is-dragging: false;

    callback drag-started(/* index */ int, /* x */ float, /* y */ float);
    callback drag-moved(/* index */ int, /* x */ float, /* y */ float);
    callback drag-ended(/* index */ int);

    background: touch.has-hover || root.is-dragging ? Theme.accent.with-alpha(root.is-dragging ? 0.72 : 0.42) : transparent;
    border-radius: 3px;

    touch := TouchArea {
        mouse-cursor: root.horizontal ? MouseCursor.row-resize : MouseCursor.col-resize;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                root.drag-started(root.handle-index, root.x / 1px + touch.mouse-x / 1px, root.y / 1px + touch.mouse-y / 1px);
            }
            if event.kind == PointerEventKind.up && event.button == PointerEventButton.left {
                root.drag-ended(root.handle-index);
            }
        }
        moved => {
            root.drag-moved(root.handle-index, root.x / 1px + touch.mouse-x / 1px, root.y / 1px + touch.mouse-y / 1px);
        }
    }
}

// ── Toolbar ──────────────────────────────────────────────────

component Toolbar inherits Rectangle {
    in property <string> layout-label;
    in property <int> window-count;
    in property <int> hidden-count;
    in property <string> refresh-label;
    in property <bool> always-on-top;
    in property <bool> animate-transitions;
    in property <string> filters-label;

    callback clicked();
    callback context-menu-requested(/* x */ float, /* y */ float);

    height: 48px;
    background: Theme.toolbar-bg;

    // Bottom separator
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
        pointer-event(event) => {
            if event.kind == PointerEventKind.up && event.button == PointerEventButton.right {
                root.context-menu-requested(touch.mouse-x / 1px, touch.mouse-y / 1px);
            }
        }
    }

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: space-between;

        // Left: brand
        Text {
            text: "Panopticon";
            color: Theme.text;
            vertical-alignment: center;
            font-size: 14px;
            font-weight: 600;
        }

        // Centre: status
        Text {
            text: root.layout-label + "  ·  " + root.window-count + " visibles  ·  "
                  + root.hidden-count + " ocultas  ·  " + root.refresh-label
                  + (root.filters-label != "" ? ("  ·  " + root.filters-label) : "");
            color: Theme.label;
            vertical-alignment: center;
            font-size: 12px;
            overflow: elide;
            horizontal-stretch: 1;
            horizontal-alignment: center;
        }

        // Right: quick info
        Text {
            text: (root.always-on-top ? "siempre visible" : "ventana normal") + "  ·  "
                  + (root.animate-transitions ? "anim on" : "anim off")
                  + "  ·  click der. header / M: menú  ·  Esc salir";
            color: Theme.muted;
            vertical-alignment: center;
            font-size: 11px;
            horizontal-alignment: right;
        }
    }
}

// ── Empty state ──────────────────────────────────────────────

component EmptyState inherits Rectangle {
    in property <string> message: "No windows available to preview";
    in property <string> helper: "Open or restore any desktop window.\nPanopticon will keep watching from the tray.";

    width: 100%;
    height: 100%;
    background: transparent;

    Rectangle {
        width: min(parent.width - 40px, 380px);
        height: 180px;
        x: max((parent.width - self.width) / 2, 0px);
        y: max((parent.height - self.height) / 2, 0px);
        background: Theme.panel-bg;
        border-width: 1px;
        border-color: Theme.border;
        border-radius: 12px;

        VerticalLayout {
            alignment: center;
            spacing: 10px;
            padding: 24px;

            // Icon placeholder
            Rectangle {
                width: 48px;
                height: 48px;
                border-radius: 24px;
                background: Theme.accent-soft;

                Text {
                    width: 100%;
                    height: 100%;
                    text: "👁";
                    font-size: 24px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }

            Text {
                text: root.message;
                color: Theme.text;
                font-size: 14px;
                horizontal-alignment: center;
            }

            Text {
                text: root.helper;
                color: Theme.muted;
                font-size: 12px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }
}

// ── Overlay scrollbar ────────────────────────────────────────

/// Data for a context menu item.
export struct MenuItemData {
    label: string,
    checked: bool,
    enabled: bool,
    is-separator: bool,
    action-id: int,
}

// ── Styled context menu ──────────────────────────────────────

component ContextMenuOverlay inherits Rectangle {
    in property <[MenuItemData]> items;
    in property <float> menu-x;
    in property <float> menu-y;
    in property <bool> menu-visible: false;
    in property <string> menu-title: "";
    in property <string> menu-subtitle: "";
    in property <image> menu-icon;

    callback item-clicked(/* action-id */ int);
    callback dismiss();

    visible: root.menu-visible;
    width: 100%;
    height: 100%;
    background: transparent;

    // Dismiss layer
    TouchArea {
        clicked => { root.dismiss(); }
    }

    // Menu panel
    Rectangle {
        x: max(8px, min(root.menu-x * 1px, parent.width - self.width - 8px));
        y: max(8px, min(root.menu-y * 1px, parent.height - self.height - 8px));
        width: 340px;
        height: menu-layout.preferred-height + (root.menu-title != "" ? 62px : 8px);
        background: Theme.panel-bg;
        border-width: 1px;
        border-color: Theme.border;
        border-radius: 8px;
        clip: true;
        drop-shadow-blur: 12px;
        drop-shadow-color: #00000066;
        drop-shadow-offset-y: 4px;

        VerticalLayout {
            spacing: 0px;

            if root.menu-title != "": Rectangle {
                height: 54px;
                background: Theme.footer-bg;

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 10px;

                    Rectangle {
                        width: 30px;
                        height: 30px;
                        border-radius: 6px;
                        background: Theme.surface;

                        if root.menu-icon.width > 0: Image {
                            x: 3px;
                            y: 3px;
                            width: 24px;
                            height: 24px;
                            source: root.menu-icon;
                            image-fit: contain;
                        }
                    }

                    VerticalLayout {
                        spacing: 2px;
                        alignment: center;

                        Text {
                            text: root.menu-title;
                            color: Theme.text;
                            font-size: 12px;
                            font-weight: 600;
                            overflow: elide;
                        }

                        if root.menu-subtitle != "": Text {
                            text: root.menu-subtitle;
                            color: Theme.muted;
                            font-size: 10.5px;
                            overflow: elide;
                        }
                    }
                }
            }

            menu-layout := VerticalLayout {
                padding: 4px;
                spacing: 0px;

                for item[i] in root.items: Rectangle {
                    height: item.is-separator ? 9px : 30px;

                    if item.is-separator: Rectangle {
                        y: 4px;
                        height: 1px;
                        width: parent.width - 8px;
                        x: 4px;
                        background: Theme.border;
                    }

                    if !item.is-separator: Rectangle {
                        background: item-touch.has-hover && item.enabled ? Theme.accent-soft : transparent;
                        border-radius: 4px;

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 8px;

                            if item.checked: Text {
                                text: "✓";
                                color: Theme.accent;
                                font-size: 12px;
                                vertical-alignment: center;
                                width: 16px;
                            }

                            if !item.checked: Rectangle {
                                width: 16px;
                            }

                            Text {
                                text: item.label;
                                color: item.enabled ? Theme.text : Theme.muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }

                        item-touch := TouchArea {
                            mouse-cursor: item.enabled ? MouseCursor.pointer : MouseCursor.default;
                            clicked => {
                                if item.enabled {
                                    root.item-clicked(item.action-id);
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

// ── Overlay scrollbar ────────────────────────────────────────

component OverlayScrollbar inherits Rectangle {
    in property <float> viewport-offset;
    in property <float> content-extent;
    in property <float> visible-size;
    in property <bool> horizontal;
    in property <bool> mouse-inside;

    property <float> max-scroll: max(content-extent - visible-size, 0.001);
    property <float> ratio: min(visible-size / max(content-extent, 0.001), 1.0);
    property <float> thumb-frac: max(ratio, 0.05);
    property <float> travel-frac: 1.0 - thumb-frac;
    property <float> scroll-frac: clamp(-viewport-offset / max-scroll, 0.0, 1.0);
    property <bool> show: mouse-inside && max-scroll > 0;

    visible: root.show;
    opacity: 0.7;

    // Track
    Rectangle {
        background: Theme.surface.with-alpha(0.3);
        border-radius: 3px;

        // Thumb
        Rectangle {
            x: root.horizontal ? (parent.width * root.travel-frac * root.scroll-frac) : 0;
            y: root.horizontal ? 0 : (parent.height * root.travel-frac * root.scroll-frac);
            width: root.horizontal ? (parent.width * root.thumb-frac) : parent.width;
            height: root.horizontal ? parent.height : (parent.height * root.thumb-frac);
            background: Theme.accent.with-alpha(0.6);
            border-radius: 3px;
        }
    }
}

// ── Main window ──────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "Panopticon — Window Viewer";
    icon: @image-url("../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 1320px;
    preferred-height: 840px;
    default-font-family: "Segoe UI";
    default-font-size: 13px;

    // ── Properties ───────────────────────────────
    in property <[ThumbnailData]> thumbnails;
    in property <[ResizeHandleData]> resize-handles;
    in property <bool> show-toolbar: true;
    in property <bool> show-window-info: true;
    in property <string> layout-label: "Grid";
    in property <int> window-count: 0;
    in property <int> hidden-count: 0;
    in property <string> refresh-label: "2s";
    in property <bool> is-always-on-top: false;
    in property <bool> animate-transitions: true;
    in property <string> filters-label: "";
    in property <float> content-width: 0;
    in property <float> content-height: 0;
    in property <bool> scroll-horizontal: false;
    in property <bool> scroll-vertical: false;
    in property <int> active-drag-index: -1;
    /// Whether to show the scrollbar overlay (auto-hides after inactivity).
    in property <bool> scroll-active: false;
    /// Optional background image behind thumbnail content.
    in property <image> background-image;

    // Shared with Rust and custom input handlers to keep scroll offsets in sync.
    in-out property <float> viewport-x: 0;
    in-out property <float> viewport-y: 0;

    // ── Callbacks ────────────────────────────────
    callback thumbnail-clicked(/* index */ int);
    callback thumbnail-right-clicked(/* index */ int, /* x */ float, /* y */ float);
    callback thumbnail-hovered(/* index */ int);
    callback toolbar-clicked();
    callback app-context-menu-requested(/* x */ float, /* y */ float);
    callback key-pressed(/* key */ string) -> bool;
    callback resize-drag-started(/* index */ int, /* x */ float, /* y */ float);
    callback resize-drag-moved(/* index */ int, /* x */ float, /* y */ float);
    callback resize-drag-ended(/* index */ int);

    // ── Context menu state ───────────────────────
    in property <[MenuItemData]> context-menu-items;
    in property <float> context-menu-x: 0;
    in property <float> context-menu-y: 0;
    in property <string> context-menu-title: "";
    in property <string> context-menu-subtitle: "";
    in property <image> context-menu-icon;
    in-out property <bool> context-menu-visible: false;
    callback context-menu-action(/* action-id */ int);

    in property <[MenuItemData]> app-menu-items;
    in property <float> app-menu-x: 0;
    in property <float> app-menu-y: 0;
    in property <string> app-menu-title: "";
    in property <string> app-menu-subtitle: "";
    in property <image> app-menu-icon;
    in-out property <bool> app-menu-visible: false;
    callback app-menu-action(/* action-id */ int);

    // ── Layout ───────────────────────────────────
    VerticalLayout {
        // Toolbar
        if root.show-toolbar: Toolbar {
            layout-label: root.layout-label;
            window-count: root.window-count;
            hidden-count: root.hidden-count;
            refresh-label: root.refresh-label;
            always-on-top: root.is-always-on-top;
            animate-transitions: root.animate-transitions;
            filters-label: root.filters-label;
            clicked => { root.toolbar-clicked(); }
            context-menu-requested(x, y) => { root.app-context-menu-requested(x, y); }
        }

        // Content area
        content-frame := Rectangle {
            clip: true;
            property <float> max-scroll-x: max(root.content-width - self.width / 1px, 0);
            property <float> max-scroll-y: max(root.content-height - self.height / 1px, 0);

            // Background image layer (behind all content).
            if root.background-image.width > 0: Image {
                width: 100%;
                height: 100%;
                source: root.background-image;
                image-fit: cover;
                opacity: 0.25;
            }

            if root.thumbnails.length == 0: EmptyState {}

            flickable := Flickable {
                viewport-width: root.scroll-horizontal ? root.content-width * 1px : parent.width;
                viewport-height: root.scroll-vertical ? root.content-height * 1px : parent.height;
                viewport-x: root.viewport-x * 1px;
                viewport-y: root.viewport-y * 1px;
                interactive: false;

                for thumb[i] in root.thumbnails: ThumbnailCard {
                    x: thumb.x * 1px;
                    y: thumb.y * 1px;
                    width: thumb.width * 1px;
                    height: thumb.height * 1px;
                    title: thumb.title;
                    app-label: thumb.app-label;
                    is-hovered: thumb.is-hovered;
                    is-active: thumb.is-active;
                    accent-color: thumb.accent-color;
                    show-footer: thumb.show-footer;
                    is-minimized: thumb.is-minimized;
                    icon-image: thumb.icon;
                    show-icon: thumb.show-icon;

                    clicked => { root.thumbnail-clicked(i); }
                    right-clicked(x, y) => { root.thumbnail-right-clicked(i, x, y); }
                    pointer-moved(x, y) => { root.thumbnail-hovered(i); }
                }
            }

            // Resize handles rendered on top of the content
            for handle[i] in root.resize-handles: ResizeHandle {
                x: handle.x * 1px;
                y: handle.y * 1px;
                width: handle.width * 1px;
                height: handle.height * 1px;
                horizontal: handle.horizontal;
                handle-index: handle.index;
                is-dragging: root.active-drag-index == handle.index;

                drag-started(idx, x, y) => { root.resize-drag-started(idx, x, y); }
                drag-moved(idx, x, y) => { root.resize-drag-moved(idx, x, y); }
                drag-ended(idx) => { root.resize-drag-ended(idx); }
            }

            // Vertical scrollbar overlay (right edge)
            if root.scroll-vertical: OverlayScrollbar {
                x: parent.width - 14px;
                y: 4px;
                width: 6px;
                height: parent.height - 8px;
                viewport-offset: root.viewport-y;
                content-extent: root.content-height;
                visible-size: parent.height / 1px;
                horizontal: false;
                mouse-inside: root.scroll-active;
            }

            // Horizontal scrollbar overlay (bottom edge)
            if root.scroll-horizontal: OverlayScrollbar {
                x: 4px;
                y: parent.height - 14px;
                width: parent.width - 8px;
                height: 6px;
                viewport-offset: root.viewport-x;
                content-extent: root.content-width;
                visible-size: parent.width / 1px;
                horizontal: true;
                mouse-inside: root.scroll-active;
            }
        }
    }

    // ── Context menu overlays ──────────────────
    // Per-window context menu
    ContextMenuOverlay {
        items: root.context-menu-items;
        menu-x: root.context-menu-x;
        menu-y: root.context-menu-y;
        menu-visible: root.context-menu-visible;
        menu-title: root.context-menu-title;
        menu-subtitle: root.context-menu-subtitle;
        menu-icon: root.context-menu-icon;
        item-clicked(action-id) => {
            root.context-menu-visible = false;
            root.context-menu-action(action-id);
        }
        dismiss => { root.context-menu-visible = false; }
    }

    // Application-level context menu
    ContextMenuOverlay {
        items: root.app-menu-items;
        menu-x: root.app-menu-x;
        menu-y: root.app-menu-y;
        menu-visible: root.app-menu-visible;
        menu-title: root.app-menu-title;
        menu-subtitle: root.app-menu-subtitle;
        menu-icon: root.app-menu-icon;
        item-clicked(action-id) => {
            root.app-menu-visible = false;
            root.app-menu-action(action-id);
        }
        dismiss => { root.app-menu-visible = false; }
    }

    // ── Keyboard ─────────────────────────────────
    forward-focus: key-handler;
    key-handler := FocusScope {
        key-pressed(event) => {
            if root.key-pressed(event.text) {
                return accept;
            }
            reject
        }
    }
}

// ── Settings window ──────────────────────────────────────────

export component SettingsWindow inherits Window {
    title: "Panopticon — Settings";
    icon: @image-url("../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 760px;
    preferred-height: 860px;
    default-font-family: "Segoe UI";
    default-font-size: 13px;

    // ── Properties ───────────────────────────────
    in-out property <bool> always-on-top-setting: false;
    in-out property <bool> animate-transitions-setting: true;
    in-out property <bool> minimize-to-tray-setting: true;
    in-out property <bool> close-to-tray-setting: true;
    in-out property <bool> preserve-aspect-ratio-setting: false;
    in-out property <bool> hide-on-select-setting: true;
    in-out property <bool> show-toolbar-setting: true;
    in-out property <bool> show-info-setting: true;
    in-out property <bool> use-system-backdrop-setting: true;
    in-out property <bool> start-in-tray-setting: false;
    in-out property <bool> locked-layout-setting: false;
    in-out property <bool> show-app-icons-setting: true;
    in property <bool> hide-on-select-enabled: true;
    in-out property <int> refresh-index: 1;
    in-out property <int> layout-index: 0;
    in property <[string]> theme-options: ["Classic Panopticon"];
    in-out property <int> theme-index: 0;
    in property <[string]> monitor-filter-options: ["All monitors"];
    in-out property <int> monitor-filter-index: 0;
    in property <[string]> tag-filter-options: ["All tags"];
    in-out property <int> tag-filter-index: 0;
    in property <[string]> app-filter-options: ["All applications"];
    in-out property <int> app-filter-index: 0;
    in property <[string]> hidden-app-options: ["No hidden apps"];
    in-out property <int> hidden-app-index: 0;
    in property <bool> can-restore-hidden: false;
    in property <string> hidden-apps-summary: "No hidden apps";
    in property <string> current-profile-label: "default";
    in-out property <string> profile-name: "";
    in property <string> known-profiles-label: "Sin perfiles guardados";
    in-out property <color> bg-preview-color: Theme.accent;
    in-out property <color> theme-preview-color: Theme.accent;
    in-out property <string> bg-color-hex: "181513";
    in-out property <string> bg-image-path: "";
    in-out property <int> fixed-width-value: 0;
    in-out property <int> fixed-height-value: 0;
    in-out property <int> dock-edge-index: 0;

    // ── Callbacks ────────────────────────────────
    callback apply();
    callback save-profile();
    callback open-profile-instance();
    callback reset-to-defaults();
    callback refresh-now();
    callback restore-hidden-selected();
    callback restore-hidden-all();
    callback closed();

    VerticalLayout {
        padding: 24px;
        spacing: 14px;

        // Title
        Text {
            text: "Settings";
            color: Theme.text;
            font-size: 20px;
            font-weight: 700;
        }

        ScrollView {
            VerticalLayout {
                spacing: 16px;
                padding-top: 8px;
                padding-right: 8px;
                padding-bottom: 12px;

                // ── Behaviour ──
                Text { text: "Behaviour"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                CheckBox { text: "Always on top"; checked <=> root.always-on-top-setting; }
                CheckBox { text: "Animate transitions"; checked <=> root.animate-transitions-setting; }
                CheckBox { text: "Minimize to tray"; checked <=> root.minimize-to-tray-setting; }
                CheckBox { text: "Close to tray"; checked <=> root.close-to-tray-setting; }
                CheckBox { text: "Default: preserve aspect ratio"; checked <=> root.preserve-aspect-ratio-setting; }
                CheckBox {
                    text: "Default: hide after selecting app";
                    checked <=> root.hide-on-select-setting;
                    enabled: root.hide-on-select-enabled;
                }
                if !root.hide-on-select-enabled: Text {
                    text: "En modo dock esta opción queda desactivada automáticamente.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                CheckBox { text: "Start hidden in tray"; checked <=> root.start-in-tray-setting; }
                CheckBox { text: "Lock layout (prevent changes)"; checked <=> root.locked-layout-setting; }

                // ── Display ──
                Rectangle { height: 8px; }
                Text { text: "Display"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                CheckBox { text: "Show toolbar"; checked <=> root.show-toolbar-setting; }
                CheckBox { text: "Show window info below thumbnails"; checked <=> root.show-info-setting; }
                CheckBox { text: "Show app icons in cells"; checked <=> root.show-app-icons-setting; }
                CheckBox { text: "Use system backdrop (Win11)"; checked <=> root.use-system-backdrop-setting; }

                // ── Theme ──
                Rectangle { height: 8px; }
                Text { text: "Theme"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "●";
                        color: root.theme-preview-color;
                        font-size: 18px;
                        vertical-alignment: center;
                    }
                    ComboBox {
                        model: root.theme-options;
                        current-index <=> root.theme-index;
                        horizontal-stretch: 1;
                    }
                }

                Text {
                    text: "Tip: press T to cycle themes quickly.";
                    color: Theme.muted;
                    font-size: 12px;
                }

                // ── Layout ──
                Rectangle { height: 8px; }
                Text { text: "Default layout"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                ComboBox {
                    model: ["Grid", "Mosaic", "Bento", "Fibonacci", "Columns", "Row", "Column"];
                    current-index <=> root.layout-index;
                }

                Text {
                    text: "Tip: press 1-7 to switch layouts, Tab to cycle, 0 to reset proportions.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // ── Refresh ──
                Rectangle { height: 8px; }
                Text { text: "Refresh interval"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                ComboBox {
                    model: ["1s", "2s", "5s", "10s"];
                    current-index <=> root.refresh-index;
                }

                Button {
                    text: "Refresh now";
                    clicked => { root.refresh-now(); }
                }

                // ── Fixed size ──
                Rectangle { height: 8px; }
                Text { text: "Fixed dimensions (0 = auto)"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                HorizontalLayout {
                    spacing: 12px;
                    Text { text: "Width:"; color: Theme.label; vertical-alignment: center; font-size: 13px; }
                    SpinBox { value <=> root.fixed-width-value; minimum: 0; maximum: 3840; }
                    Text { text: "Height:"; color: Theme.label; vertical-alignment: center; font-size: 13px; }
                    SpinBox { value <=> root.fixed-height-value; minimum: 0; maximum: 2160; }
                }

                // ── Dock ──
                Rectangle { height: 8px; }
                Text { text: "Dock position"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                ComboBox {
                    model: ["Floating (no dock)", "Left", "Right", "Top", "Bottom"];
                    current-index <=> root.dock-edge-index;
                }

                // ── Filters ──
                Rectangle { height: 8px; }
                Text { text: "Filters"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                Text { text: "Monitor"; color: Theme.muted; font-size: 13px; }
                ComboBox {
                    model: root.monitor-filter-options;
                    current-index <=> root.monitor-filter-index;
                }

                Text { text: "Tag"; color: Theme.muted; font-size: 13px; }
                ComboBox {
                    model: root.tag-filter-options;
                    current-index <=> root.tag-filter-index;
                }

                Text { text: "Application"; color: Theme.muted; font-size: 13px; }
                ComboBox {
                    model: root.app-filter-options;
                    current-index <=> root.app-filter-index;
                }

                Text {
                    text: "Los filtros también se reflejan en el header y en el menú contextual de la app.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // ── Background ──
                Rectangle { height: 8px; }
                Text { text: "Background colour (RGB hex)"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: "●";
                        color: root.bg-preview-color;
                        font-size: 18px;
                        vertical-alignment: center;
                    }
                    Text { text: "#"; color: Theme.muted; vertical-alignment: center; font-size: 13px; }
                    LineEdit {
                        text <=> root.bg-color-hex;
                        horizontal-alignment: left;
                        font-size: 13px;
                    }
                }

                Text { text: "Background image path (optional)"; color: Theme.muted; font-size: 13px; }
                LineEdit {
                    text <=> root.bg-image-path;
                    horizontal-alignment: left;
                    font-size: 13px;
                    placeholder-text: "C:\\path\\to\\image.png";
                }

                // ── Profiles ──
                Rectangle { height: 8px; }
                Text { text: "Profiles"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                Text {
                    text: "Perfil actual: " + root.current-profile-label;
                    color: Theme.label;
                    font-size: 13px;
                }

                HorizontalLayout {
                    spacing: 8px;
                    Text { text: "Perfil:"; color: Theme.muted; vertical-alignment: center; font-size: 13px; }
                    LineEdit {
                        text <=> root.profile-name;
                        horizontal-stretch: 1;
                        font-size: 13px;
                    }
                }

                Text {
                    text: root.known-profiles-label;
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 10px;
                    Button {
                        text: "Guardar perfil";
                        clicked => { root.save-profile(); }
                    }
                    Button {
                        text: "Abrir otra instancia";
                        clicked => { root.open-profile-instance(); }
                    }
                }

                // ── Hidden apps ──
                Rectangle { height: 8px; }
                Text { text: "Hidden apps"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                Text {
                    text: root.hidden-apps-summary;
                    color: Theme.label;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                ComboBox {
                    model: root.hidden-app-options;
                    current-index <=> root.hidden-app-index;
                    enabled: root.can-restore-hidden;
                }

                HorizontalLayout {
                    spacing: 10px;
                    Button {
                        text: "Restore selected";
                        enabled: root.can-restore-hidden;
                        clicked => { root.restore-hidden-selected(); }
                    }
                    Button {
                        text: "Restore all";
                        enabled: root.can-restore-hidden;
                        clicked => { root.restore-hidden-all(); }
                    }
                }

                if !root.can-restore-hidden: Text {
                    text: "No hay apps ocultas para restaurar ahora mismo.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // ── Shortcuts ──
                Rectangle { height: 8px; }
                Text { text: "Keyboard shortcuts"; color: Theme.accent; font-size: 14px; font-weight: 600; }

                Text {
                    text: "1-7: layouts  ·  Tab: cycle layout  ·  0: reset ratios\n"
                        + "T: cycle theme  ·  A: animations  ·  H: toolbar\n"
                        + "I: window info  ·  P: always on top  ·  O: settings\n"
                        + "M / right-click header: app menu  ·  R: refresh\n"
                        + "Alt: toggle toolbar  ·  Esc: exit";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }

                // Spacer
                Rectangle { vertical-stretch: 1; }
            }
        }

        // Action buttons
        HorizontalLayout {
            spacing: 12px;
            alignment: end;

            Button {
                text: "Reset defaults";
                clicked => { root.reset-to-defaults(); }
            }

            Button {
                text: "Apply";
                clicked => { root.apply(); }
            }

            Button {
                text: "Close";
                clicked => {
                    root.closed();
                }
            }
        }
    }
}

export component TagDialogWindow inherits Window {
    title: "Panopticon — Create tag";
    icon: @image-url("../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 420px;
    preferred-height: 260px;
    default-font-family: "Segoe UI";
    default-font-size: 13px;

    in property <string> app-label: "";
    in-out property <string> tag-name: "";
    in-out property <int> color-index: 0;
    property <color> selected-color: color-index == 1 ? #5CA9FF
        : color-index == 2 ? #3CCF91
        : color-index == 3 ? #FF6B8A
        : color-index == 4 ? #9B7BFF
        : color-index == 5 ? #F4B740
        : #D29A5C;

    callback create();
    callback closed();

    VerticalLayout {
        padding: 20px;
        spacing: 12px;

        Text {
            text: "Create custom tag";
            color: Theme.text;
            font-size: 18px;
            font-weight: 700;
        }

        Text {
            text: "Application: " + root.app-label;
            color: Theme.label;
            font-size: 12px;
            wrap: word-wrap;
        }

        Rectangle { height: 4px; }

        Text {
            text: "Tag name";
            color: Theme.accent;
            font-size: 13px;
            font-weight: 600;
        }

        LineEdit {
            text <=> root.tag-name;
            horizontal-alignment: left;
            font-size: 12px;
        }

        Text {
            text: "Preset colour";
            color: Theme.accent;
            font-size: 13px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 8px;
            Text {
                text: "●";
                color: root.selected-color;
                font-size: 18px;
                vertical-alignment: center;
            }
            ComboBox {
                model: ["Amber", "Sky", "Mint", "Rose", "Violet", "Sun"];
                current-index <=> root.color-index;
                horizontal-stretch: 1;
            }
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            spacing: 12px;
            alignment: end;

            Button {
                text: "Create and assign";
                clicked => { root.create(); }
            }

            Button {
                text: "Close";
                clicked => { root.closed(); }
            }
        }
    }
}
