import { Tr, Theme as ThemeGlobal, ThumbnailData as ThumbnailModel, ResizeHandleData as ResizeHandleModel } from "common.slint";
import { ThumbnailCard } from "components/thumbnail_card.slint";
import { ResizeHandle } from "components/resize_handle.slint";
import { Toolbar } from "components/toolbar.slint";
import { EmptyState } from "components/empty_state.slint";
import { OverlayScrollbar } from "components/overlay_scrollbar.slint";

export { Tr, Theme, ThumbnailData, ResizeHandleData } from "common.slint";
export { ThemePreviewData } from "common.slint";
export { SettingsWindow } from "windows/settings_window.slint";
export { TagDialogWindow } from "windows/tag_dialog_window.slint";

export component MainWindow inherits Window {
    title: Tr.main-window-title;
    icon: @image-url("../assets/icon.svg");
    background: root.canvas-background-color;
    preferred-width: 1320px;
    preferred-height: 840px;
    default-font-family: "Miranda Sans";
    default-font-size: 14px;

    in property <[ThumbnailModel]> thumbnails;
    in property <[ResizeHandleModel]> resize-handles;
    in property <bool> show-toolbar: true;
    in property <bool> show-window-info: true;
    in property <string> layout-label: Tr.layout-grid-label;
    in property <int> window-count: 0;
    in property <int> hidden-count: 0;
    in property <string> refresh-label: "2s";
    in property <bool> is-always-on-top: false;
    in property <bool> animate-transitions: true;
    in property <string> filters-label: "";
    in property <float> content-width: 0;
    in property <float> content-height: 0;
    in property <bool> scroll-horizontal: false;
    in property <bool> scroll-vertical: false;
    in property <int> active-drag-index: -1;
    in property <bool> resize-locked: false;
    in property <bool> scroll-active: false;
    in property <image> background-image;
    in property <color> canvas-background-color: ThemeGlobal.bg;
    in property <int> background-image-fit-index: 0;

    in-out property <float> viewport-x: 0;
    in-out property <float> viewport-y: 0;

    callback thumbnail-clicked(/* index */ int);
    callback thumbnail-close-clicked(/* index */ int);
    callback thumbnail-right-clicked(/* index */ int, /* x */ float, /* y */ float);
    callback thumbnail-drag-ended(/* index */ int, /* drop_x */ float, /* drop_y */ float);
    callback toolbar-clicked();
    callback app-context-menu-requested(/* x */ float, /* y */ float);
    callback key-pressed(/* key */ string) -> bool;
    callback resize-drag-started(/* index */ int, /* x */ float, /* y */ float);
    callback resize-drag-moved(/* index */ int, /* x */ float, /* y */ float);
    callback resize-drag-ended(/* index */ int);

    VerticalLayout {
        if root.show-toolbar: Toolbar {
            layout-label: root.layout-label;
            window-count: root.window-count;
            hidden-count: root.hidden-count;
            refresh-label: root.refresh-label;
            always-on-top: root.is-always-on-top;
            animate-transitions: root.animate-transitions;
            filters-label: root.filters-label;
            clicked => { root.toolbar-clicked(); }
            context-menu-requested(x, y) => { root.app-context-menu-requested(x, y); }
        }

        content-frame := Rectangle {
            clip: true;
            property <float> max-scroll-x: max(root.content-width - self.width / 1px, 0);
            property <float> max-scroll-y: max(root.content-height - self.height / 1px, 0);

            if root.background-image.width > 0: Image {
                width: 100%;
                height: 100%;
                source: root.background-image;
                image-fit: root.background-image-fit-index == 1 ? contain
                    : root.background-image-fit-index == 2 ? fill
                    : root.background-image-fit-index == 3 ? preserve
                    : cover;
                opacity: 0.25;
            }

            if root.thumbnails.length == 0: EmptyState {}

            flickable := Flickable {
                viewport-width: root.scroll-horizontal ? root.content-width * 1px : parent.width;
                viewport-height: root.scroll-vertical ? root.content-height * 1px : parent.height;
                viewport-x: root.viewport-x * 1px;
                viewport-y: root.viewport-y * 1px;
                interactive: false;

                for thumb[i] in root.thumbnails: ThumbnailCard {
                    x: thumb.x * 1px + self.drag-offset-x * 1px;
                    y: thumb.y * 1px + self.drag-offset-y * 1px;
                    width: thumb.width * 1px;
                    height: thumb.height * 1px;
                    title: thumb.title;
                    app-label: thumb.app-label;
                    is-active: thumb.is-active;
                    accent-color: thumb.accent-color;
                    show-footer: thumb.show-footer;
                    is-minimized: thumb.is-minimized;
                    icon-image: thumb.icon;
                    show-icon: thumb.show-icon;

                    clicked => { root.thumbnail-clicked(i); }
                    close-requested => { root.thumbnail-close-clicked(i); }
                    right-clicked(x, y) => { root.thumbnail-right-clicked(i, x, y); }
                    move-drag-ended(dx, dy) => { root.thumbnail-drag-ended(i, thumb.x + dx, thumb.y + dy); }
                }
            }

            for handle[i] in root.resize-handles: ResizeHandle {
                x: handle.x * 1px;
                y: handle.y * 1px;
                width: handle.width * 1px;
                height: handle.height * 1px;
                horizontal: handle.horizontal;
                handle-index: handle.index;
                is-dragging: root.active-drag-index == handle.index;
                is-locked: root.resize-locked;

                drag-started(idx, x, y) => { root.resize-drag-started(idx, x, y); }
                drag-moved(idx, x, y) => { root.resize-drag-moved(idx, x, y); }
                drag-ended(idx) => { root.resize-drag-ended(idx); }
            }

            if root.scroll-vertical: OverlayScrollbar {
                x: parent.width - 14px;
                y: 4px;
                width: 6px;
                height: parent.height - 8px;
                viewport-offset: root.viewport-y;
                content-extent: root.content-height;
                visible-size: parent.height / 1px;
                horizontal: false;
                mouse-inside: root.scroll-active;
            }

            if root.scroll-horizontal: OverlayScrollbar {
                x: 4px;
                y: parent.height - 14px;
                width: parent.width - 8px;
                height: 6px;
                viewport-offset: root.viewport-x;
                content-extent: root.content-width;
                visible-size: parent.width / 1px;
                horizontal: true;
                mouse-inside: root.scroll-active;
            }
        }
    }

    forward-focus: key-handler;
    key-handler := FocusScope {
        key-pressed(event) => {
            if root.key-pressed(event.text) {
                return accept;
            }
            reject
        }
    }
}
