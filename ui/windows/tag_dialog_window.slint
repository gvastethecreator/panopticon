import { Tr, Theme } from "../common.slint";
import {
    CustomButton,
    CustomComboBox,
    CustomLineEdit,
} from "../components/custom_themed_widgets.slint";

export component TagDialogWindow inherits Window {
    title: Tr.tag-window-title;
    icon: @image-url("../../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 420px;
    preferred-height: 260px;
    default-font-family: "Miranda Sans";
    default-font-size: 14px;

    in property <string> app-label: "";
    in-out property <string> tag-name: "";
    in-out property <int> color-index: 0;
    property <color> selected-color: color-index == 1 ? #5CA9FF : color-index == 2 ? #3CCF91 : color-index == 3 ? #FF6B8A : color-index == 4 ? #9B7BFF : color-index == 5 ? #F4B740 : #D29A5C;

    callback create();
    callback closed();

    VerticalLayout {
        padding: 20px;
        spacing: 12px;

        Text {
            text: Tr.tag-title;
            color: Theme.text;
            font-size: 18px;
            font-weight: 700;
        }

        Text {
            text: Tr.tag-app-label + root.app-label;
            color: Theme.label;
            font-size: 13px;
            wrap: word-wrap;
        }

        Rectangle {
            height: 4px;
        }

        Text {
            text: Tr.tag-name-label;
            color: Theme.accent;
            font-size: 13px;
            font-weight: 600;
        }

        CustomLineEdit {
            height: 34px;
            text <=> root.tag-name;
            placeholder: "work";
        }

        Text {
            text: Tr.tag-preset-colour;
            color: Theme.accent;
            font-size: 13px;
            font-weight: 600;
        }

        HorizontalLayout {
            spacing: 8px;
            Rectangle {
                width: 22px;
                height: 32px;
                border-radius: 4px;
                background: root.selected-color;
                y: 0px;
            }

            CustomComboBox {
                options: Tr.tag-colour-options;
                selected-index <=> root.color-index;
                horizontal-stretch: 1;
                height: 32px;
            }
        }

        Rectangle {
            vertical-stretch: 1;
        }

        HorizontalLayout {
            spacing: 12px;
            alignment: end;

            CustomButton {
                height: 34px;
                accent: true;
                text: Tr.tag-create-assign;
                clicked => {
                    root.create();
                }
            }

            CustomButton {
                height: 34px;
                text: Tr.action-close;
                clicked => {
                    root.closed();
                }
            }
        }
    }
}
