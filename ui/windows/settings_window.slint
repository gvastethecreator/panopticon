import {
    CheckBox,
    ComboBox,
    LineEdit,
    ScrollView,
    Button,
    SpinBox,
    Slider,
} from "std-widgets.slint";
import { Tr, Theme, ThemePreviewData } from "../common.slint";

    component Divider inherits Rectangle {
    height: 1px;
    background: Theme.border.with-alpha(72%);
}

    component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <string> subtext;
    in property <image> icon;
    in property <bool> active: false;
    callback clicked();

    height: 34px;
    border-radius: 4px;
    border-width: 2px;
    border-color: root.active ? Theme.accent.with-alpha(52%) : transparent;
    background: root.active ? Theme.accent-soft.with-alpha(44%) : touch.has-hover ? Theme.surface.with-alpha(52%) : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 10px;
        alignment: start;

        Image {
            width: 24px;
            height: 24px;
            source: root.icon;
            image-fit: contain;
            colorize: root.active ? Theme.accent : Theme.muted;
        }

        VerticalLayout {
            spacing: 1px;
            alignment: start;
            vertical-stretch: 1;
            padding-top: 4px;

            Text {
                text: root.label;
                color: root.active ? Theme.text : Theme.label;
                font-size: 14px;
                font-weight: root.active ? 650 : 500;
                overflow: elide;
            }
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

    component PageHeader inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> subtitle;

    height: 55px;
    border-radius: 0px;
    background: transparent;
    border-width: 0px;
    border-color: transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 5px;
        padding-bottom: 4px;
        spacing: 10px;
        alignment: start;

        Image {
            width: 24px;
            height: 24px;
            source: root.icon;
            image-fit: contain;
            colorize: Theme.accent;
        }

        VerticalLayout {
            spacing: 3px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: root.title;
                color: Theme.text;
                font-size: 18px;
                font-weight: 500;
            }

            Text {
                text: root.subtitle;
                color: Theme.muted;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }
}

    component SectionTitle inherits Rectangle {
    in property <image> icon;
    in property <string> text;
    in property <string> helper;

    height: 42px;
    background: transparent;

    HorizontalLayout {
        spacing: 10px;
        padding: 8px;
        alignment: start;

        Image {
            width: 19px;
            height: 19px;
            source: root.icon;
            image-fit: contain;
            colorize: Theme.accent;
        }

        VerticalLayout {
            spacing: 1px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: root.text;
                color: Theme.accent;
                font-size: 16px;
                font-weight: 400;
            }
        }
    }
}

    component ToggleSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in-out property <bool> checked: false;
    in property <bool> enabled: true;

    min-height: 44px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 0px;
        padding-bottom: 10px;
        spacing: 15px;
        alignment: start;

        Image {
            width: 22px;
            height: 22px;
            source: root.icon;
            image-fit: contain;
            colorize: root.enabled ? Theme.label : Theme.muted;
        }

        CheckBox {
            text: "";
            checked <=> root.checked;
            enabled: root.enabled;
            height: 22px;
        }

        VerticalLayout {
            spacing: 1px;
            vertical-stretch: 1;

            Text {
                text: root.title;
                color: root.enabled ? Theme.text : Theme.muted;
                font-size: 14px;
                font-weight: 400;
                wrap: word-wrap;
            }

            Text {
                text: root.description;
                color: Theme.muted;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
    }
}

    component SelectSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in property <[string]> options: [];
    in-out property <int> selected-index: 0;
    in property <bool> enabled: true;

    min-height: 30px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 2px;
        padding-bottom: 4px;
        spacing: 8px;

        ComboBox {
            width: 140px;
            height: 26px;
            model: root.options;
            current-index <=> root.selected-index;
            enabled: root.enabled;
        }
    }
}

    component SelectSettingPanel inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in property <[string]> options: [];
    in-out property <int> selected-index: 0;
    in property <bool> enabled: true;
    in property <length> combo-width: 220px;

    min-height: 86px;
    border-radius: 4px;
    border-width: 2px;
    border-color: Theme.border.with-alpha(52%);
    background: Theme.card-bg.with-alpha(92%);

    VerticalLayout {
        padding: 14px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 10px;
            alignment: start;

            Image {
                width: 20px;
                height: 20px;
                source: root.icon;
                image-fit: contain;
                colorize: root.enabled ? Theme.accent : Theme.muted;
            }

            VerticalLayout {
                spacing: 4px;
                vertical-stretch: 1;

                Text {
                    text: root.title;
                    color: root.enabled ? Theme.text : Theme.muted;
                    font-size: 14px;
                    font-weight: 700;
                    wrap: word-wrap;
                }
            }
        }

        ComboBox {
            width: root.combo-width;
            height: 34px;
            model: root.options;
            current-index <=> root.selected-index;
            enabled: root.enabled;
        }
    }
}

    component TextFieldSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in-out property <string> value: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    callback committed();

    min-height: 64px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    VerticalLayout {
        padding-left: 8px;
        padding-right: 8px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 10px;

            Image {
                width: 18px;
                height: 18px;
                source: root.icon;
                image-fit: contain;
                colorize: Theme.label;
            }

            VerticalLayout {
                spacing: 3px;
                vertical-stretch: 1;

                Text {
                    text: root.title;
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    wrap: word-wrap;
                }
            }
        }

        edit := LineEdit {
            text <=> root.value;
            height: 32px;
            placeholder-text: root.placeholder;
            enabled: root.enabled;
            accepted(_) => {
                root.committed();
            }
            changed has-focus => {
                if !self.has-focus {
                    root.committed();
                }
            }
        }
    }
}

    component ThemePreviewCard inherits Rectangle {
    in property <ThemePreviewData> theme;
    in property <bool> selected: false;
    callback picked(/* index */ int);

    border-radius: 14px;
    border-width: selected ? 2px : 1px;
    border-color: selected ? Theme.accent : Theme.border.with-alpha(62%);
    background: theme.surface.with-alpha(94%);

    Rectangle {
        x: 0;
        y: 0;
        width: 100%;
        height: 44px;
        border-radius: 14px;
        background: theme.bg;

        Rectangle {
            x: 14px;
            y: 11px;
            width: 12px;
            height: 12px;
            border-radius: 6px;
            background: theme.accent;
        }

        Rectangle {
            x: 32px;
            y: 11px;
            width: 12px;
            height: 12px;
            border-radius: 6px;
            background: theme.text;
        }
    }

    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        padding-top: 56px;
        padding-bottom: 12px;
        spacing: 3px;

        Text {
            text: root.theme.label;
            color: Theme.text;
            font-size: 13px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            text: root.theme.subtitle;
            color: Theme.muted;
            font-size: 11px;
            wrap: word-wrap;
        }
    }

    touch := TouchArea {
        clicked => {
            root.picked(root.theme.index);
        }
        scroll-event(_) => {
            reject;
        }
    }
}

    component FooterButton inherits Rectangle {
    in property <string> text;
    in property <bool> accent: false;
    callback clicked();

    height: 36px;
    min-width: 122px;
    border-radius: 4px;
    border-width: accent ? 0px : 2px;
    border-color: Theme.border.with-alpha(64%);
    background: accent ? (touch.has-hover ? Theme.accent.darker(8%) : Theme.accent) : (touch.has-hover ? Theme.surface : transparent);

    Text {
        width: 100%;
        height: 100%;
        text: root.text;
        color: accent ? Theme.bg : Theme.label;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

    export component SettingsWindow inherits Window {
    title: Tr.settings-window-title;
    icon: @image-url("../../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 1180px;
    preferred-height: 820px;
    default-font-family: "Miranda Sans";
    default-font-size: 14px;

    in-out property <bool> always-on-top-setting: false;
    in-out property <bool> animate-transitions-setting: true;
    in-out property <bool> minimize-to-tray-setting: true;
    in-out property <bool> close-to-tray-setting: true;
    in-out property <bool> preserve-aspect-ratio-setting: false;
    in-out property <bool> hide-on-select-setting: true;
    in-out property <bool> show-toolbar-setting: true;
    in-out property <bool> show-info-setting: true;
    in-out property <bool> use-system-backdrop-setting: true;
    in-out property <bool> start-in-tray-setting: false;
    in-out property <bool> run-at-startup-setting: false;
    in-out property <bool> locked-layout-setting: false;
    in-out property <bool> lock-cell-resize-setting: false;
    in-out property <bool> show-app-icons-setting: true;
    in property <bool> hide-on-select-enabled: true;
    in property <bool> default-layout-enabled: true;
    in-out property <int> language-index: 0;
    in-out property <int> refresh-index: 1;
    in-out property <int> layout-index: 0;
    in property <[string]> theme-options: ["Classic Panopticon"];
    in property <[ThemePreviewData]> theme-preview-model: [];
    in-out property <int> theme-index: 0;
    in property <[string]> monitor-filter-options: [Tr.all-monitors-label];
    in-out property <int> monitor-filter-index: 0;
    in property <[string]> tag-filter-options: [Tr.all-tags-label];
    in-out property <int> tag-filter-index: 0;
    in property <[string]> app-filter-options: [Tr.all-apps-label];
    in-out property <int> app-filter-index: 0;
    in property <[string]> hidden-app-options: [Tr.no-hidden-label];
    in-out property <int> hidden-app-index: 0;
    in property <bool> can-restore-hidden: false;
    in property <string> hidden-apps-summary: Tr.no-hidden-label;
    in property <string> current-profile-label: "default";
    in-out property <string> profile-name: "";
    in property <string> known-profiles-label: Tr.no-saved-profiles-label;
    in property <string> app-version-text: "";
    in property <string> update-status-text: "";
    in property <bool> update-check-running: false;
    in property <[string]> available-profile-options: [Tr.default-profile-label];
    in-out property <int> available-profile-index: 0;
    in-out property <color> bg-preview-color: Theme.accent;
    in-out property <color> theme-preview-color: Theme.accent;
    in-out property <string> bg-color-hex: "181513";
    in-out property <int> bg-red-value: 24;
    in-out property <int> bg-green-value: 21;
    in-out property <int> bg-blue-value: 19;
    in-out property <string> bg-image-path: "";
    in-out property <image> bg-image-preview;
    in-out property <int> bg-image-fit-index: 0;
    in-out property <int> bg-image-opacity-value: 25;
    in-out property <int> fixed-width-value: 0;
    in-out property <int> fixed-height-value: 0;
    in-out property <int> thumbnail-render-scale-value: 100;
    in-out property <int> dock-edge-index: 0;
    in-out property <int> dock-column-thickness-value: 0;
    in-out property <int> dock-row-thickness-value: 0;
    in-out property <int> group-windows-index: 0;
    in-out property <string> shortcut-layout-grid: "1";
    in-out property <string> shortcut-layout-mosaic: "2";
    in-out property <string> shortcut-layout-bento: "3";
    in-out property <string> shortcut-layout-fibonacci: "4";
    in-out property <string> shortcut-layout-columns: "5";
    in-out property <string> shortcut-layout-row: "6";
    in-out property <string> shortcut-layout-column: "7";
    in-out property <string> shortcut-reset-layout: "0";
    in-out property <string> shortcut-cycle-layout: "Tab";
    in-out property <string> shortcut-cycle-theme: "T";
    in-out property <string> shortcut-toggle-animations: "A";
    in-out property <string> shortcut-toggle-toolbar: "H";
    in-out property <string> shortcut-toggle-window-info: "I";
    in-out property <string> shortcut-toggle-always-on-top: "P";
    in-out property <string> shortcut-open-settings: "O";
    in-out property <string> shortcut-open-menu: "M";
    in-out property <string> shortcut-global-activate: "Ctrl+Alt+P";
    in-out property <string> shortcut-refresh-now: "R";
    in-out property <string> shortcut-exit-app: "Esc";
    in-out property <bool> alt-toolbar-shortcut-enabled: true;
    in-out property <bool> suspend-live-apply: false;

    in-out property <int> current-page: 0;
    property <bool> dock-mode-active: root.dock-edge-index != 0;
    property <bool> dock-column-mode: root.dock-edge-index == 1 || root.dock-edge-index == 2;

    callback apply();
    callback request-live-apply();
    callback save-profile();
    callback load-selected-profile();
    callback open-profile-instance();
    callback open-about();
    callback reset-to-defaults();
    callback refresh-now();
    callback check-updates-now();
    callback restore-hidden-selected();
    callback restore-hidden-all();
    callback browse-background-image();
    callback clear-background-image();
    callback apply-bg-color-hex(string);
    callback apply-bg-color-rgb(int, int, int);
    callback closed();

    request-live-apply => {
        if (!root.suspend-live-apply) {
            root.apply();
        }
    }

    changed always-on-top-setting => {
        root.request-live-apply();
    }
    changed animate-transitions-setting => {
        root.request-live-apply();
    }
    changed minimize-to-tray-setting => {
        root.request-live-apply();
    }
    changed close-to-tray-setting => {
        root.request-live-apply();
    }
    changed preserve-aspect-ratio-setting => {
        root.request-live-apply();
    }
    changed hide-on-select-setting => {
        root.request-live-apply();
    }
    changed show-toolbar-setting => {
        root.request-live-apply();
    }
    changed show-info-setting => {
        root.request-live-apply();
    }
    changed use-system-backdrop-setting => {
        root.request-live-apply();
    }
    changed start-in-tray-setting => {
        root.request-live-apply();
    }
    changed run-at-startup-setting => {
        root.request-live-apply();
    }
    changed locked-layout-setting => {
        root.request-live-apply();
    }
    changed lock-cell-resize-setting => {
        root.request-live-apply();
    }
    changed show-app-icons-setting => {
        root.request-live-apply();
    }
    changed language-index => {
        root.request-live-apply();
    }
    changed refresh-index => {
        root.request-live-apply();
    }
    changed layout-index => {
        root.request-live-apply();
    }
    changed theme-index => {
        root.request-live-apply();
    }
    changed monitor-filter-index => {
        root.request-live-apply();
    }
    changed tag-filter-index => {
        root.request-live-apply();
    }
    changed app-filter-index => {
        root.request-live-apply();
    }
    changed bg-image-fit-index => {
        root.request-live-apply();
    }
    changed bg-image-opacity-value => {
        root.request-live-apply();
    }
    changed fixed-width-value => {
        root.request-live-apply();
    }
    changed fixed-height-value => {
        root.request-live-apply();
    }
    changed thumbnail-render-scale-value => {
        root.request-live-apply();
    }
    changed dock-edge-index => {
        root.request-live-apply();
    }
    changed dock-column-thickness-value => {
        root.request-live-apply();
    }
    changed dock-row-thickness-value => {
        root.request-live-apply();
    }
    changed group-windows-index => {
        root.request-live-apply();
    }
    changed alt-toolbar-shortcut-enabled => {
        root.request-live-apply();
    }

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 45px;
            background: Theme.bg;

            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                padding-top: 12px;
                padding-bottom: 12px;
                alignment: space-between;

                VerticalLayout {
                    spacing: 3px;
                    alignment: center;

                    Text {
                        text: Tr.settings-title;
                        color: Theme.text;
                        font-size: 24px;
                        font-weight: 400;
                    }
                }

                Rectangle {
                    width: 170px;
                    height: 42px;
                    border-radius: 4px;
                    border-width: 2px;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 10px;

                        Rectangle {
                            width: 3px;
                            height: 32px;
                            border-radius: 2px;
                            background: Theme.accent.with-alpha(50%);
                        }

                        VerticalLayout {
                            spacing: 0px;
                            alignment: start;

                            Text {
                                text: Tr.settings-profile-badge;
                                color: Theme.muted;
                                font-size: 10px;
                            }

                            Text {
                                text: root.current-profile-label;
                                color: Theme.text;
                                font-size: 13px;
                                font-weight: 400;
                                overflow: elide;
                            }
                        }
                    }

                    profile-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.current-page = 3;
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            visible: true;

            Rectangle {
                width: 250px;
                background: Theme.bg;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;

                    SidebarItem {
                        label: Tr.settings-nav-behaviour-display-title;
                        subtext: Tr.settings-nav-behaviour-display-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-display.svg");
                        active: root.current-page == 0;
                        clicked => {
                            root.current-page = 0;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-filters-title;
                        subtext: Tr.settings-nav-filters-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-filter.svg");
                        active: root.current-page == 1;
                        clicked => {
                            root.current-page = 1;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-theme-background-title;
                        subtext: Tr.settings-nav-theme-background-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-theme.svg");
                        active: root.current-page == 2;
                        clicked => {
                            root.current-page = 2;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-profiles-title;
                        subtext: Tr.settings-nav-profiles-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-profile.svg");
                        active: root.current-page == 3;
                        clicked => {
                            root.current-page = 3;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-shortcuts-title;
                        subtext: Tr.settings-nav-shortcuts-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                        active: root.current-page == 4;
                        clicked => {
                            root.current-page = 4;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-advanced-title;
                        subtext: Tr.settings-nav-advanced-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-advanced.svg");
                        active: root.current-page == 5;
                        clicked => {
                            root.current-page = 5;
                        }
                    }

                    Rectangle {
                        vertical-stretch: 0;

                        Image {
                            source: @image-url("../../assets/mascot.svg");
                            vertical-alignment: ImageVerticalAlignment.bottom;
                            vertical-tiling: ImageTiling.none;
                            width: 190px;
                            height: 270px;
                            y: 180px;
                            horizontal-alignment: ImageHorizontalAlignment.center;
                            horizontal-tiling: ImageTiling.none;
                            image-fit: ImageFit.contain;
                            image-rendering: ImageRendering.smooth;
                        }
                    }
                }
            }

            Rectangle {
                width: 2px;
                background: Theme.border.with-alpha(30%);
            }

            ScrollView {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                VerticalLayout {
                    padding: 10px;
                    spacing: 14px;

                    if root.current-page == 0: VerticalLayout {

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-display.svg");
                            title: Tr.settings-page-behaviour-display-title;
                            subtitle: Tr.settings-page-behaviour-display-subtitle;
                        }

                        spacing: 6px;

                        ToggleSettingCard {
                            enabled: true;
                            icon: @image-url("../../assets/ui-icons/option-always-on-top.svg");
                            title: Tr.settings-option-always-on-top-title;
                            description: Tr.settings-option-always-on-top-description;
                            checked <=> root.always-on-top-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-animate.svg");
                            title: Tr.settings-option-animate-transitions-title;
                            description: Tr.settings-option-animate-transitions-description;
                            checked <=> root.animate-transitions-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-minimize-tray.svg");
                            title: Tr.settings-option-minimize-to-tray-title;
                            description: Tr.settings-option-minimize-to-tray-description;
                            checked <=> root.minimize-to-tray-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-close-tray.svg");
                            title: Tr.settings-option-close-to-tray-title;
                            description: Tr.settings-option-close-to-tray-description;
                            checked <=> root.close-to-tray-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-aspect-ratio.svg");
                            title: Tr.settings-option-preserve-aspect-ratio-title;
                            description: Tr.settings-option-preserve-aspect-ratio-description;
                            checked <=> root.preserve-aspect-ratio-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                            title: Tr.settings-option-hide-on-select-title;
                            description: root.hide-on-select-enabled ? Tr.settings-option-hide-on-select-description : Tr.dock-mode-hint;
                            checked <=> root.hide-on-select-setting;
                            enabled: root.hide-on-select-enabled;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-start-hidden.svg");
                            title: Tr.settings-option-start-in-tray-title;
                            description: Tr.settings-option-start-in-tray-description;
                            checked <=> root.start-in-tray-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-settings.svg");
                            title: Tr.settings-option-run-at-startup-title;
                            description: Tr.settings-option-run-at-startup-description;
                            checked <=> root.run-at-startup-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-lock-layout.svg");
                            title: Tr.settings-option-lock-layout-title;
                            description: Tr.settings-option-lock-layout-description;
                            checked <=> root.locked-layout-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-lock-resize.svg");
                            title: Tr.settings-option-lock-cell-resize-title;
                            description: Tr.settings-option-lock-cell-resize-description;
                            checked <=> root.lock-cell-resize-setting;
                        }

                        Divider {
                            height: 2px;
                            background: Theme.border.with-alpha(72%);
                        }

                        PageHeader {
                            height: 58px;
                            icon: @image-url("../../assets/ui-icons/option-visibility.svg");
                            title: Tr.settings-section-display-title;
                            subtitle: Tr.settings-section-display-helper;
                        }

                        HorizontalLayout {
                            spacing: 16px;

                            SelectSettingPanel {
                                horizontal-stretch: 1;
                                combo-width: 220px;
                                icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                title: Tr.settings-option-default-layout-title;
                                options: Tr.layout-options;
                                selected-index <=> root.layout-index;
                                enabled: root.default-layout-enabled;
                            }

                            SelectSettingPanel {
                                horizontal-stretch: 1;
                                combo-width: 220px;
                                icon: @image-url("../../assets/ui-icons/option-dock.svg");
                                title: Tr.settings-option-dock-position-title;
                                options: Tr.dock-options;
                                selected-index <=> root.dock-edge-index;
                            }
                        }

                        if root.dock-mode-active: Rectangle {
                            border-radius: 4px;
                            border-width: 2px;
                            border-color: Theme.border.with-alpha(50%);
                            background: Theme.card-bg.with-alpha(92%);

                            VerticalLayout {
                                padding: 14px;
                                spacing: 12px;

                                HorizontalLayout {
                                    spacing: 10px;
                                    alignment: space-between;

                                    HorizontalLayout {
                                        spacing: 10px;

                                        Image {
                                            width: 20px;
                                            height: 20px;
                                            source: @image-url("../../assets/ui-icons/option-dock.svg");
                                            image-fit: contain;
                                            colorize: Theme.accent;
                                        }

                                        VerticalLayout {
                                            spacing: 4px;

                                            Text {
                                                text: Tr.settings-section-dock-thickness-title;
                                                color: Theme.text;
                                                font-size: 14px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: Tr.settings-section-dock-thickness-helper;
                                                color: Theme.muted;
                                                font-size: 11px;
                                                wrap: word-wrap;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 30px;
                                        border-radius: 15px;
                                        border-width: 1px;
                                        border-color: Theme.accent.with-alpha(60%);
                                        background: Theme.accent-soft.with-alpha(48%);

                                        Text {
                                            width: 100%;
                                            height: 100%;
                                            text: root.dock-column-mode ? Tr.layout-column-label : Tr.layout-row-label;
                                            color: Theme.text;
                                            font-size: 12px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 16px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: Theme.border.with-alpha(64%);
                                        background: root.dock-column-mode ? Theme.accent-soft.with-alpha(32%) : Theme.surface.with-alpha(48%);

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 8px;

                                            Text {
                                                text: Tr.layout-column-label;
                                                color: Theme.text;
                                                font-size: 13px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: Tr.settings-width-label;
                                                color: Theme.muted;
                                                font-size: 11px;
                                            }

                                            SpinBox {
                                                height: 34px;
                                                value <=> root.dock-column-thickness-value;
                                                minimum: 0;
                                                maximum: 3840;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: Theme.border.with-alpha(64%);
                                        background: !root.dock-column-mode ? Theme.accent-soft.with-alpha(32%) : Theme.surface.with-alpha(48%);

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 8px;

                                            Text {
                                                text: Tr.layout-row-label;
                                                color: Theme.text;
                                                font-size: 13px;
                                                font-weight: 700;
                                            }

                                            Text {
                                                text: Tr.settings-height-label;
                                                color: Theme.muted;
                                                font-size: 11px;
                                            }

                                            SpinBox {
                                                height: 34px;
                                                value <=> root.dock-row-thickness-value;
                                                minimum: 0;
                                                maximum: 2160;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        if !root.dock-mode-active: Rectangle {

                            VerticalLayout {
                                padding: 14px;
                                spacing: 12px;

                                HorizontalLayout {
                                    spacing: 10px;

                                    Image {
                                        width: 20px;
                                        height: 20px;
                                        source: @image-url("../../assets/ui-icons/option-layout.svg");
                                        image-fit: contain;
                                        colorize: Theme.accent;
                                    }

                                    VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: Tr.settings-section-floating-window-size-title;
                                            color: Theme.text;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }

                                        Text {
                                            text: Tr.settings-section-floating-window-size-helper;
                                            color: Theme.muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 16px;

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        border-radius: 4px;
                                        border-width: 2px;
                                        border-color: Theme.border.with-alpha(64%);
                                        background: Theme.surface.with-alpha(48%);

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 8px;

                                            Text {
                                                text: Tr.settings-width-label;
                                                color: Theme.text;
                                                font-size: 13px;
                                                font-weight: 700;
                                            }

                                            SpinBox {
                                                height: 34px;
                                                value <=> root.fixed-width-value;
                                                minimum: 0;
                                                maximum: 3840;
                                            }
                                        }
                                    }

                                    Rectangle {
                                        horizontal-stretch: 1;
                                        border-radius: 4px;
                                        border-width: 2px;
                                        border-color: Theme.border.with-alpha(64%);
                                        background: Theme.surface.with-alpha(48%);

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 8px;

                                            Text {
                                                text: Tr.settings-height-label;
                                                color: Theme.text;
                                                font-size: 13px;
                                                font-weight: 700;
                                            }

                                            SpinBox {
                                                height: 34px;
                                                value <=> root.fixed-height-value;
                                                minimum: 0;
                                                maximum: 2160;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        Rectangle {

                            VerticalLayout {
                                padding: 14px;
                                spacing: 12px;

                                HorizontalLayout {
                                    spacing: 10px;

                                    Image {
                                        width: 20px;
                                        height: 20px;
                                        source: @image-url("../../assets/ui-icons/option-image-fit.svg");
                                        image-fit: contain;
                                        colorize: Theme.accent;
                                    }

                                    VerticalLayout {
                                        spacing: 4px;

                                        Text {
                                            text: Tr.settings-option-thumbnail-render-scale-title;
                                            color: Theme.text;
                                            font-size: 14px;
                                            font-weight: 700;
                                        }

                                        Text {
                                            text: Tr.settings-option-thumbnail-render-scale-description;
                                            color: Theme.muted;
                                            font-size: 11px;
                                            wrap: word-wrap;
                                        }
                                    }
                                }

                                HorizontalLayout {
                                    spacing: 10px;

                                    Slider {
                                        horizontal-stretch: 1;
                                        minimum: 50;
                                        maximum: 100;
                                        value: root.thumbnail-render-scale-value;
                                        changed value => {
                                            root.thumbnail-render-scale-value = self.value;
                                        }
                                    }

                                    SpinBox {
                                        width: 76px;
                                        minimum: 50;
                                        maximum: 100;
                                        value <=> root.thumbnail-render-scale-value;
                                    }

                                    Text {
                                        text: "%";
                                        color: Theme.label;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                            title: Tr.settings-option-show-toolbar-title;
                            description: Tr.settings-option-show-toolbar-description;
                            checked <=> root.show-toolbar-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-window-info.svg");
                            title: Tr.settings-option-show-info-title;
                            description: Tr.settings-option-show-info-description;
                            checked <=> root.show-info-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                            title: Tr.settings-option-show-app-icons-title;
                            description: Tr.settings-option-show-app-icons-description;
                            checked <=> root.show-app-icons-setting;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-backdrop.svg");
                            title: Tr.settings-option-use-system-backdrop-title;
                            description: Tr.settings-option-use-system-backdrop-description;
                            checked <=> root.use-system-backdrop-setting;
                        }
                    }

                    if root.current-page == 1: VerticalLayout {
                        spacing: 10px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-filter.svg");
                            title: Tr.settings-page-filters-title;
                            subtitle: Tr.settings-page-filters-subtitle;
                        }

                        HorizontalLayout {
                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-monitor.svg");
                                title: Tr.settings-option-monitor-filter-title;
                                description: Tr.settings-option-monitor-filter-description;
                                options: root.monitor-filter-options;
                                selected-index <=> root.monitor-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-tag.svg");
                                title: Tr.settings-option-tag-filter-title;
                                description: Tr.settings-option-tag-filter-description;
                                options: root.tag-filter-options;
                                selected-index <=> root.tag-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                                title: Tr.settings-option-app-filter-title;
                                description: Tr.settings-option-app-filter-description;
                                options: root.app-filter-options;
                                selected-index <=> root.app-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-group.svg");
                                title: Tr.settings-option-group-windows-title;
                                description: Tr.settings-option-group-windows-description;
                                options: Tr.group-options;
                                selected-index <=> root.group-windows-index;
                            }
                        }

                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;

                            SectionTitle {
                                icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                                text: Tr.settings-section-hidden-apps-title;
                                helper: Tr.settings-section-hidden-apps-helper;
                            }

                            Text {
                                text: root.hidden-apps-summary;
                                color: Theme.label;
                                font-size: 13px;
                                wrap: word-wrap;
                            }

                            ComboBox {
                                height: 40px;
                                model: root.hidden-app-options;
                                current-index <=> root.hidden-app-index;
                                enabled: root.can-restore-hidden;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                Button {
                                    height: 30px;
                                    text: Tr.action-restore-selected;
                                    enabled: root.can-restore-hidden;
                                    clicked => {
                                        root.restore-hidden-selected();
                                    }
                                }

                                Button {
                                    height: 30px;
                                    text: Tr.action-restore-all;
                                    enabled: root.can-restore-hidden;
                                    clicked => {
                                        root.restore-hidden-all();
                                    }
                                }
                            }
                        }
                    }

                    if root.current-page == 2: VerticalLayout {
                        spacing: 12px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-theme.svg");
                            title: Tr.settings-page-theme-background-title;
                            subtitle: Tr.settings-page-theme-background-subtitle;
                        }

                        HorizontalLayout {
                            spacing: 16px;
                            alignment: start;
                            vertical-stretch: 1;

                            Rectangle {
                                width: 360px;
                                height: 760px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(50%);
                                background: Theme.card_bg.with-alpha(92%);
                                clip: true;

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/section-theme.svg");
                                        text: Tr.settings-section-theme-grid-title;
                                        helper: Tr.settings-section-theme-grid-helper;
                                    }

                                    theme-list-scroll := ScrollView {
                                        vertical-stretch: 1;
                                        viewport-width: theme-list-content.width + 24px;
                                        viewport-height: theme-list-content.height + 24px;

                                        theme-list-content := Rectangle {
                                            x: 12px;
                                            y: 12px;
                                            width: max(theme-list-scroll.width - 24px, 280px);
                                            height: max((root.theme-preview-model.length * 118px) + 12px, theme-list-scroll.height - 24px);

                                            for theme[index] in root.theme-preview-model: ThemePreviewCard {
                                                width: theme-list-content.width;
                                                height: 106px;
                                                x: 0px;
                                                y: index * 118px;
                                                theme: theme;
                                                selected: root.theme-index == theme.index;
                                                picked(idx) => {
                                                    root.theme-index = idx;
                                                    root.theme-preview-color = theme.accent;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 16px;

                                Rectangle {
                                    height: 208px;
                                    border-radius: 4px;
                                    border-width: 2px;
                                    border-color: Theme.border.with-alpha(50%);
                                    background: Theme.card_bg.with-alpha(92%);

                                    VerticalLayout {
                                        padding: 14px;
                                        spacing: 10px;

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-paint.svg");
                                            title: Tr.settings-option-custom-canvas-colour-title;
                                            value <=> root.bg-color-hex;
                                            placeholder: "181513";
                                            committed => {
                                                root.apply-bg-color-hex(root.bg-color-hex);
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-rgb-picker-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                            }

                                            HorizontalLayout {
                                                spacing: 8px;

                                                Text {
                                                    text: Tr.settings-channel-red-label;
                                                    color: Theme.muted;
                                                    vertical-alignment: center;
                                                }

                                                SpinBox {
                                                    width: 72px;
                                                    minimum: 0;
                                                    maximum: 255;
                                                    value: root.bg-red-value;
                                                    changed value => {
                                                        root.bg-red-value = self.value;
                                                        root.apply-bg-color-rgb(root.bg-red-value, root.bg-green-value, root.bg-blue-value);
                                                    }
                                                }

                                                Text {
                                                    text: Tr.settings-channel-green-label;
                                                    color: Theme.muted;
                                                    vertical-alignment: center;
                                                }

                                                SpinBox {
                                                    width: 72px;
                                                    minimum: 0;
                                                    maximum: 255;
                                                    value: root.bg-green-value;
                                                    changed value => {
                                                        root.bg-green-value = self.value;
                                                        root.apply-bg-color-rgb(root.bg-red-value, root.bg-green-value, root.bg-blue-value);
                                                    }
                                                }

                                                Text {
                                                    text: Tr.settings-channel-blue-label;
                                                    color: Theme.muted;
                                                    vertical-alignment: center;
                                                }

                                                SpinBox {
                                                    width: 72px;
                                                    minimum: 0;
                                                    maximum: 255;
                                                    value: root.bg-blue-value;
                                                    changed value => {
                                                        root.bg-blue-value = self.value;
                                                        root.apply-bg-color-rgb(root.bg-red-value, root.bg-green-value, root.bg-blue-value);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 290px;
                                    border-radius: 4px;
                                    border-width: 2px;
                                    border-color: Theme.border.with-alpha(50%);
                                    background: Theme.card_bg.with-alpha(92%);

                                    VerticalLayout {
                                        padding: 14px;
                                        spacing: 10px;

                                        SectionTitle {
                                            icon: @image-url("../../assets/ui-icons/option-image.svg");
                                            text: Tr.settings-section-background-image-title;
                                            helper: Tr.settings-section-background-image-helper;
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;

                                            Button {
                                                height: 40px;
                                                text: Tr.action-browse-image;
                                                clicked => {
                                                    root.browse-background-image();
                                                }
                                            }

                                            Button {
                                                height: 40px;
                                                text: Tr.action-clear-image;
                                                clicked => {
                                                    root.clear-background-image();
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-file-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                            }

                                            LineEdit {
                                                text <=> root.bg-image-path;
                                                height: 32px;
                                                placeholder-text: "C:/Users/.../background.png";
                                                accepted(_) => {
                                                    root.apply();
                                                }
                                                changed has-focus => {
                                                    if !self.has-focus {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-fit-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                            }

                                            ComboBox {
                                                width: 180px;
                                                height: 32px;
                                                model: Tr.image-fit-options;
                                                current-index <=> root.bg-image-fit-index;
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-opacity-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                                height: 20px;
                                            }

                                            HorizontalLayout {
                                                spacing: 10px;

                                                Slider {
                                                    horizontal-stretch: 1;
                                                    minimum: 0;
                                                    maximum: 100;
                                                    value: root.bg-image-opacity-value;
                                                    changed value => {
                                                        root.bg-image-opacity-value = self.value;
                                                    }
                                                }

                                                SpinBox {
                                                    width: 72px;
                                                    height: 32px;
                                                    minimum: 0;
                                                    maximum: 100;
                                                    value <=> root.bg-image-opacity-value;
                                                }
                                            }
                                        }
                                    }
                                }

                                Rectangle {
                                    height: 220px;
                                    border-radius: 4px;
                                    border-width: 2px;
                                    border-color: Theme.border.with-alpha(50%);
                                    background: Theme.card_bg.with-alpha(92%);

                                    VerticalLayout {
                                        padding-top: 8px;
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        spacing: 8px;

                                        SectionTitle {
                                            icon: @image-url("../../assets/ui-icons/section-theme.svg");
                                            text: Tr.settings-section-preview-title;
                                            helper: Tr.settings-section-preview-helper;
                                        }

                                        Rectangle {
                                            height: 148px;
                                            border-radius: 12px;
                                            background: root.bg-preview-color;
                                            clip: true;

                                            if root.bg-image-preview.width > 0: Image {
                                                width: 100%;
                                                height: 100%;
                                                source: root.bg-image-preview;
                                                image-fit: root.bg-image-fit-index == 1 ? contain : root.bg-image-fit-index == 2 ? fill : root.bg-image-fit-index == 3 ? preserve : cover;
                                                opacity: root.bg-image-opacity-value / 100;
                                            }

                                            Rectangle {
                                                x: 12px;
                                                y: 12px;
                                                width: 68px;
                                                height: 22px;
                                                border-radius: 11px;
                                                background: Theme.panel_bg.with-alpha(84%);

                                                Text {
                                                    width: 100%;
                                                    height: 100%;
                                                    text: root.bg-color-hex;
                                                    color: Theme.text;
                                                    font-size: 10px;
                                                    horizontal-alignment: center;
                                                    vertical-alignment: center;
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.current-page == 3: VerticalLayout {
                        spacing: 16px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-profile.svg");
                            title: Tr.settings-page-profiles-title;
                            subtitle: Tr.settings-page-profiles-subtitle;
                        }

                        HorizontalLayout {
                            spacing: 16px;

                            Rectangle {
                                width: 430px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(50%);
                                background: Theme.card_bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                        text: Tr.settings-section-load-profile-title;
                                        helper: Tr.settings-section-load-profile-helper;
                                    }

                                    SelectSettingCard {
                                        icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                        title: Tr.settings-option-available-profile-title;
                                        description: Tr.settings-option-available-profile-description;
                                        options: root.available-profile-options;
                                        selected-index <=> root.available-profile-index;
                                    }

                                    HorizontalLayout {
                                        spacing: 10px;

                                        Button {
                                            height: 40px;
                                            text: Tr.action-load-profile;
                                            clicked => {
                                                root.load-selected-profile();
                                            }
                                        }

                                        Button {
                                            text: Tr.open-instance-btn;
                                            clicked => {
                                                root.open-profile-instance();
                                            }
                                        }
                                    }

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                        text: Tr.settings-section-edit-profile-title;
                                        helper: Tr.settings-section-edit-profile-helper;
                                    }

                                    Rectangle {
                                        border-radius: 12px;
                                        border-width: 1px;
                                        border-color: Theme.border.with-alpha(68%);
                                        background: Theme.surface.with-alpha(56%);
                                        height: 60px;

                                        VerticalLayout {
                                            padding: 12px;
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-current-profile-card-title;
                                                color: Theme.muted;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: root.current-profile-label;
                                                color: Theme.text;
                                                font-size: 15px;
                                                font-weight: 700;
                                                overflow: elide;
                                            }
                                        }
                                    }

                                    TextFieldSettingCard {
                                        icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                        title: Tr.settings-option-profile-name-title;
                                        description: Tr.settings-option-profile-name-description;
                                        value <=> root.profile-name;
                                        placeholder: "workspace-a";
                                    }

                                    HorizontalLayout {
                                        spacing: 10px;
                                        Button {
                                            height: 40px;
                                            text: Tr.save-profile-btn;
                                            clicked => {
                                                root.save-profile();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(50%);
                                background: Theme.card_bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                        text: Tr.settings-section-saved-profiles-title;
                                        helper: Tr.settings-section-saved-profiles-helper;
                                    }

                                    Text {
                                        text: root.known-profiles-label;
                                        color: Theme.label;
                                        font-size: 12px;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }

                        Rectangle {
                            border-radius: 4px;
                            border-color: Theme.border.with-alpha(20%);
                            background: Theme.surface.with-alpha(20%);
                            height: 90px;
                            width: 440px;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 6px;

                                Text {
                                    text: Tr.settings-tips-title;
                                    color: Theme.accent;
                                    font-size: 11px;
                                    font-weight: 700;
                                }

                                Text {
                                    text: Tr.settings-tips-body;
                                    color: Theme.muted;
                                    font-size: 11.5px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    if root.current-page == 4: VerticalLayout {
                        spacing: 16px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                            title: Tr.settings-page-shortcuts-title;
                            subtitle: Tr.settings-page-shortcuts-subtitle;
                        }

                        ToggleSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                            title: Tr.settings-shortcut-alt-toolbar-title;
                            description: Tr.settings-shortcut-alt-toolbar-description;
                            checked <=> root.alt-toolbar-shortcut-enabled;
                        }

                        Rectangle {
                            height: 540px;
                            border-radius: 4px;
                            border-width: 2px;
                            border-color: Theme.border.with-alpha(50%);
                            background: Theme.card_bg.with-alpha(92%);
                            clip: true;

                            ScrollView {
                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                        text: Tr.settings-section-layout-bindings-title;
                                        helper: Tr.settings-section-layout-bindings-helper;
                                    }

                                    HorizontalLayout {
                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-grid-title;
                                            description: Tr.settings-shortcut-layout-grid-description;
                                            value <=> root.shortcut-layout-grid;
                                            placeholder: "1";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-mosaic-title;
                                            description: Tr.settings-shortcut-layout-mosaic-description;
                                            value <=> root.shortcut-layout-mosaic;
                                            placeholder: "2";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-bento-title;
                                            description: Tr.settings-shortcut-layout-bento-description;
                                            value <=> root.shortcut-layout-bento;
                                            placeholder: "3";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-fibonacci-title;
                                            description: Tr.settings-shortcut-layout-fibonacci-description;
                                            value <=> root.shortcut-layout-fibonacci;
                                            placeholder: "4";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        padding-top: 10px;
                                        padding-bottom: 10px;

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-columns-title;
                                            description: Tr.settings-shortcut-layout-columns-description;
                                            value <=> root.shortcut-layout-columns;
                                            placeholder: "5";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-row-title;
                                            description: Tr.settings-shortcut-layout-row-description;
                                            value <=> root.shortcut-layout-row;
                                            placeholder: "6";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-column-title;
                                            description: Tr.settings-shortcut-layout-column-description;
                                            value <=> root.shortcut-layout-column;
                                            placeholder: "7";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-reset-layout-title;
                                            description: Tr.settings-shortcut-reset-layout-description;
                                            value <=> root.shortcut-reset-layout;
                                            placeholder: "0";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-cycle.svg");
                                            title: Tr.settings-shortcut-cycle-layout-title;
                                            description: Tr.settings-shortcut-cycle-layout-description;
                                            value <=> root.shortcut-cycle-layout;
                                            placeholder: "Tab";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    Divider {
                                        height: 2px;
                                        background: Theme.border.with-alpha(72%);
                                    }

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                                        text: Tr.settings-section-dashboard-actions-title;
                                        helper: Tr.settings-section-dashboard-actions-helper;
                                    }

                                    HorizontalLayout {
                                        padding-top: 10px;
                                        padding-bottom: 10px;

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-palette.svg");
                                            title: Tr.settings-shortcut-cycle-theme-title;
                                            description: Tr.settings-shortcut-cycle-theme-description;
                                            value <=> root.shortcut-cycle-theme;
                                            placeholder: "T";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-animate.svg");
                                            title: Tr.settings-shortcut-toggle-animations-title;
                                            description: Tr.settings-shortcut-toggle-animations-description;
                                            value <=> root.shortcut-toggle-animations;
                                            placeholder: "A";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                                            title: Tr.settings-shortcut-toggle-toolbar-title;
                                            description: Tr.settings-shortcut-toggle-toolbar-description;
                                            value <=> root.shortcut-toggle-toolbar;
                                            placeholder: "H";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-window-info.svg");
                                            title: Tr.settings-shortcut-toggle-window-info-title;
                                            description: Tr.settings-shortcut-toggle-window-info-description;
                                            value <=> root.shortcut-toggle-window-info;
                                            placeholder: "I";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        padding-top: 10px;
                                        padding-bottom: 10px;

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-always-on-top.svg");
                                            title: Tr.settings-shortcut-toggle-always-on-top-title;
                                            description: Tr.settings-shortcut-toggle-always-on-top-description;
                                            value <=> root.shortcut-toggle-always-on-top;
                                            placeholder: "P";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                            title: Tr.settings-shortcut-open-settings-title;
                                            description: Tr.settings-shortcut-open-settings-description;
                                            value <=> root.shortcut-open-settings;
                                            placeholder: "O";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-menu.svg");
                                            title: Tr.settings-shortcut-open-menu-title;
                                            description: Tr.settings-shortcut-open-menu-description;
                                            value <=> root.shortcut-open-menu;
                                            placeholder: "M";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                            title: Tr.settings-shortcut-global-activate-title;
                                            description: Tr.settings-shortcut-global-activate-description;
                                            value <=> root.shortcut-global-activate;
                                            placeholder: "Ctrl+Alt+P";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    HorizontalLayout {
                                        padding-top: 10px;
                                        padding-bottom: 10px;
                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                            title: Tr.settings-shortcut-refresh-now-title;
                                            description: Tr.settings-shortcut-refresh-now-description;
                                            value <=> root.shortcut-refresh-now;
                                            placeholder: "R";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        TextFieldSettingCard {
                                            icon: @image-url("../../assets/ui-icons/option-exit.svg");
                                            title: Tr.settings-shortcut-exit-app-title;
                                            description: Tr.settings-shortcut-exit-app-description;
                                            value <=> root.shortcut-exit-app;
                                            placeholder: "Esc";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.current-page == 5: VerticalLayout {
                        spacing: 16px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-advanced.svg");
                            title: Tr.settings-page-advanced-title;
                            subtitle: Tr.settings-page-advanced-subtitle;
                        }

                        SelectSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-option-refresh-interval-title;
                            description: Tr.settings-option-refresh-interval-description;
                            options: ["1s", "2s", "5s", "10s"];
                            selected-index <=> root.refresh-index;
                        }

                        VerticalLayout {
                            padding: 14px;
                            spacing: 10px;

                            SectionTitle {
                                icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                text: Tr.settings-section-manual-refresh-title;
                                helper: Tr.settings-section-manual-refresh-helper;
                            }

                            Button {
                                height: 40px;
                                width: 120px;
                                text: Tr.action-refresh-now;
                                clicked => {
                                    root.refresh-now();
                                }
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                Button {
                                    height: 40px;
                                    text: Tr.action-check-updates;
                                    enabled: !root.update-check-running;
                                    clicked => {
                                        root.check-updates-now();
                                    }
                                }

                                Text {
                                    text: root.update-status-text;
                                    color: Theme.label;
                                    vertical-alignment: center;
                                    wrap: word-wrap;
                                }
                            }

                            Text {
                                text: Tr.settings-version-label + " " + root.app-version-text;
                                color: Theme.muted;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 62px;
            background: Theme.bg.with-alpha(30%);

            VerticalLayout {
                Divider {
                    vertical-stretch: 0;
                    height: 2px;
                }

                HorizontalLayout {
                    padding-left: 24px;
                    padding-right: 24px;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    spacing: 10px;
                    alignment: space-between;
                    vertical-stretch: 1;

                    SelectSettingCard {
                        icon: @image-url("../../assets/ui-icons/option-settings.svg");
                        title: Tr.settings-option-language-title;
                        description: Tr.settings-option-language-description;
                        options: Tr.language-options;
                        selected-index <=> root.language-index;
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        FooterButton {
                            text: Tr.action-about;
                            clicked => {
                                root.open-about();
                            }
                        }

                        FooterButton {
                            text: Tr.action-reset-defaults;
                            clicked => {
                                root.reset-to-defaults();
                            }
                        }

                        FooterButton {
                            text: Tr.action-close;
                            clicked => {
                                root.closed();
                            }
                        }
                    }
                }
            }
        }
    }
}
