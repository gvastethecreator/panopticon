import {
    ScrollView,
} from "std-widgets.slint";
import { Tr, Theme, ThemePreviewData } from "../common.slint";
import {
    CustomCheckBox,
    CustomComboBox,
    CustomLineEdit,
    CustomButton,
    CustomSpinBox,
    CustomSlider,
    SectionCard,
    SectionHeader,
    StatusPill,
    InlineWarning,
    SettingRow,
} from "../components/custom_themed_widgets.slint";

    component Divider inherits Rectangle {
    height: 1px;
    background: Theme.border.with-alpha(72%);
}

    component SidebarItem inherits Rectangle {
    in property <string> label;
    in property <string> subtext;
    in property <image> icon;
    in property <bool> active: false;
    callback clicked();

    height: 34px;
    border-radius: 4px;
    border-width: 2px;
    border-color: root.active ? Theme.accent.with-alpha(52%) : transparent;
    background: root.active ? Theme.accent-soft.with-alpha(44%) : touch.has-hover ? Theme.surface.with-alpha(52%) : transparent;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        padding-top: 4px;
        padding-bottom: 4px;
        spacing: 10px;
        alignment: start;

        Image {
            width: 24px;
            height: 24px;
            source: root.icon;
            image-fit: contain;
            colorize: root.active ? Theme.accent : Theme.muted;
        }

        VerticalLayout {
            spacing: 1px;
            alignment: start;
            vertical-stretch: 1;
            padding-top: 4px;

            Text {
                text: root.label;
                color: root.active ? Theme.text : Theme.label;
                font-size: 14px;
                font-weight: root.active ? 650 : 500;
                overflow: elide;
            }
        }
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

    component PageHeader inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> subtitle;

    height: 55px;
    border-radius: 0px;
    background: transparent;
    border-width: 0px;
    border-color: transparent;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 5px;
        padding-bottom: 4px;
        spacing: 10px;
        alignment: start;

        Image {
            width: 24px;
            height: 24px;
            source: root.icon;
            image-fit: contain;
            colorize: Theme.accent;
        }

        VerticalLayout {
            spacing: 3px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: root.title;
                color: Theme.text;
                font-size: 18px;
                font-weight: 500;
            }

            Text {
                text: root.subtitle;
                color: Theme.muted;
                font-size: 12px;
                wrap: word-wrap;
            }
        }
    }
}

    component SectionTitle inherits Rectangle {
    in property <image> icon;
    in property <string> text;
    in property <string> helper;

    height: 42px;
    background: transparent;

    HorizontalLayout {
        spacing: 10px;
        padding: 8px;
        alignment: start;

        Image {
            width: 19px;
            height: 19px;
            source: root.icon;
            image-fit: contain;
            colorize: Theme.accent;
        }

        VerticalLayout {
            spacing: 1px;
            alignment: start;
            vertical-stretch: 1;

            Text {
                text: root.text;
                color: Theme.accent;
                font-size: 16px;
                font-weight: 400;
            }
        }
    }
}

    component ToggleSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in-out property <bool> checked: false;
    in property <bool> enabled: true;

    min-height: 44px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 0px;
        padding-bottom: 10px;
        spacing: 15px;
        alignment: start;

        Image {
            width: 22px;
            height: 22px;
            source: root.icon;
            image-fit: contain;
            colorize: root.enabled ? Theme.label : Theme.muted;
        }

        CustomCheckBox {
            checked <=> root.checked;
            enabled: root.enabled;
        }

        VerticalLayout {
            spacing: 1px;
            vertical-stretch: 1;

            Text {
                text: root.title;
                color: root.enabled ? Theme.text : Theme.muted;
                font-size: 14px;
                font-weight: 400;
                wrap: word-wrap;
            }

            Text {
                text: root.description;
                color: Theme.muted;
                font-size: 11px;
                wrap: word-wrap;
            }
        }
    }
}

    component SelectSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in property <[string]> options: [];
    in-out property <int> selected-index: 0;
    in property <bool> enabled: true;

    min-height: 30px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    VerticalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 2px;
        padding-bottom: 4px;
        spacing: 8px;

        CustomComboBox {
            width: 140px;
            height: 26px;
            options: root.options;
            selected-index <=> root.selected-index;
            enabled: root.enabled;
        }
    }
}

    component SelectSettingPanel inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in property <[string]> options: [];
    in-out property <int> selected-index: 0;
    in property <bool> enabled: true;
    in property <length> combo-width: 220px;

    min-height: 70px;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 0px;
        padding-bottom: 10px;
        spacing: 15px;
        alignment: start;

        Image {
            width: 22px;
            height: 22px;
            source: root.icon;
            image-fit: contain;
            colorize: root.enabled ? Theme.label : Theme.muted;
        }

        VerticalLayout {
            spacing: 10px;
            vertical-stretch: 1;

            Text {
                text: root.title;
                color: root.enabled ? Theme.text : Theme.muted;
                font-size: 14px;
                font-weight: 400;
                wrap: word-wrap;
            }

            CustomComboBox {
                width: root.combo-width;
                height: 34px;
                options: root.options;
                selected-index <=> root.selected-index;
                enabled: root.enabled;
            }
        }
    }
}

component TextFieldSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in-out property <string> value: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    callback committed();

    min-height: 64px;
    border-radius: 0px;
    border-width: 0px;
    border-color: transparent;
    background: transparent;

    VerticalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 10px;

            Image {
                width: 18px;
                height: 18px;
                source: root.icon;
                image-fit: contain;
                colorize: Theme.label;
            }

            VerticalLayout {
                spacing: 3px;
                vertical-stretch: 1;

                Text {
                    text: root.title;
                    color: Theme.text;
                    font-size: 14px;
                    font-weight: 600;
                    wrap: word-wrap;
                }
            }
        }

        edit := CustomLineEdit {
            text <=> root.value;
            height: 32px;
            placeholder: root.placeholder;
            enabled: root.enabled;
            accepted(_) => {
                root.committed();
            }
            focus-lost => {
                root.committed();
            }
        }
    }
}

component KeyFieldSettingCard inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <string> description;
    in-out property <string> value: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    callback committed();

    min-height: 30px;
    border-radius: 0px;
    border-width: 2px;
    background: transparent;

    HorizontalLayout {
        padding-left: 0px;
        padding-right: 0px;
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 4px;

        HorizontalLayout {
            spacing: 10px;

            Image {
                width: 28px;
                height: 28px;
                source: root.icon;
                image-fit: contain;
                colorize: Theme.label;
            }

            VerticalLayout {
                spacing: 3px;
                vertical-stretch: 1;

                Text {
                    text: root.title;
                    color: Theme.text;
                    min-width: 100px;
                    font-size: 14px;
                    font-weight: 500;
                    wrap: word-wrap;
                    vertical-alignment: center;
                }
            }

            edit := CustomLineEdit {
                text <=> root.value;
                height: 28px;
                min-width: 30px;
                placeholder: root.placeholder;
                enabled: root.enabled;
                accepted(_) => {
                    root.committed();
                }
                focus-lost => {
                    root.committed();
                }
            }
        }
    }
}

    component ThemeColorSettingRow inherits Rectangle {
    in property <string> label;
    in-out property <string> value: "";
    in property <string> placeholder: "";
    in property <color> preview-color: Theme.accent;
    callback committed();

    height: 42px;
    border-radius: 4px;
    border-width: 2px;
    border-color: Theme.border.with-alpha(10%);
    background: Theme.surface.with-alpha(48%);

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        padding-top: 8px;
        padding-bottom: 8px;
        spacing: 10px;
        alignment: start;

        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 4px;
            border-width: 1px;
            border-color: Theme.border.with-alpha(72%);
            background: root.preview-color;
        }

        Text {
            text: root.label;
            color: Theme.text;
            font-size: 12.5px;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-stretch: 1;
            width: 85px;
        }

        Text {
            text: "#";
            color: Theme.text.with-alpha(72%);
            font-size: 12.5px;
            font-weight: 700;
            vertical-alignment: center;
        }

        edit := CustomLineEdit {
            width: 106px;
            height: 28px;
            text <=> root.value;
            placeholder: root.placeholder;
            accepted(_) => {
                root.committed();
            }
            focus-lost => {
                root.committed();
            }
        }
    }
}

    component ThemePreviewMiniCanvas inherits Rectangle {
    in property <ThemePreviewData> theme;

    border-radius: 12px;
    border-width: 1px;
    border-color: root.theme.accent.with-alpha(34%);
    background: root.theme.bg;
    clip: true;

    Rectangle {
        x: 10px;
        y: 10px;
        width: 34px;
        height: 8px;
        border-radius: 4px;
        background: root.theme.surface.with-alpha(92%);
    }

    Rectangle {
        x: 50px;
        y: 10px;
        width: 22px;
        height: 8px;
        border-radius: 4px;
        background: root.theme.accent.with-alpha(94%);
    }

    Rectangle {
        x: 10px;
        y: 25px;
        width: 72px;
        height: 5px;
        border-radius: 3px;
        background: root.theme.text.with-alpha(42%);
    }

    Rectangle {
        x: 10px;
        y: 35px;
        width: 52px;
        height: 5px;
        border-radius: 3px;
        background: root.theme.text.with-alpha(24%);
    }

    Rectangle {
        x: 10px;
        y: parent.height - 28px;
        width: parent.width - 20px;
        height: 18px;
        border-radius: 8px;
        background: root.theme.surface.with-alpha(94%);

        Rectangle {
            x: 8px;
            y: 7px;
            width: 24px;
            height: 4px;
            border-radius: 2px;
            background: root.theme.accent;
        }

        Rectangle {
            x: 38px;
            y: 7px;
            width: 26px;
            height: 4px;
            border-radius: 2px;
            background: root.theme.text.with-alpha(24%);
        }
    }
}

    component ThemePreviewCard inherits Rectangle {
    in property <ThemePreviewData> theme;
    in property <bool> selected: false;
    callback picked(/* index */ int);

    border-radius: 12px;
    border-width: selected ? 2px : 1px;
    border-color: root.selected ? root.theme.accent : touch.has-hover ? Theme.border.with-alpha(82%) : Theme.border.with-alpha(58%);
    background: root.selected ? Theme.accent-soft.with-alpha(18%) : touch.has-hover ? Theme.surface.with-alpha(38%) : Theme.card_bg.with-alpha(90%);

    mini-preview := ThemePreviewMiniCanvas {
        x: 12px;
        y: 10px;
        width: 102px;
        height: max(root.height - 20px, 60px);
        theme: root.theme;
    }

    Text {
        x: mini-preview.x + mini-preview.width + 14px;
        y: 14px;
        width: max(root.width - mini-preview.width - 58px, 78px);
        text: root.theme.label;
        color: Theme.text;
        font-size: 13px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: mini-preview.x + mini-preview.width + 14px;
        y: 34px;
        width: max(root.width - mini-preview.width - 58px, 78px);
        text: root.theme.subtitle;
        color: Theme.muted;
        font-size: 10px;
        overflow: elide;
    }

    Rectangle {
        x: mini-preview.x + mini-preview.width + 14px;
        y: root.height - 28px;
        width: max(root.width - mini-preview.width - 70px, 72px);
        height: 8px;
        background: transparent;

        Rectangle {
            width: 30px;
            height: parent.height;
            border-radius: parent.height / 2;
            background: root.theme.accent;
        }

        Rectangle {
            x: 36px;
            width: 22px;
            height: parent.height;
            border-radius: parent.height / 2;
            background: root.theme.surface;
        }

        Rectangle {
            x: 64px;
            width: min(parent.width - 64px, 28px);
            height: parent.height;
            border-radius: parent.height / 2;
            background: root.theme.text.with-alpha(18%);
        }
    }

    Rectangle {
        x: root.width - 28px;
        y: 12px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        border-width: 2px;
        border-color: root.selected ? root.theme.accent : Theme.border.with-alpha(80%);
        background: root.selected ? root.theme.accent.with-alpha(14%) : transparent;

        Rectangle {
            x: 4px;
            y: 4px;
            width: 4px;
            height: 4px;
            border-radius: 2px;
            background: root.selected ? root.theme.accent : transparent;
        }
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.picked(root.theme.index);
        }
    }
}

    component FooterButton inherits Rectangle {
    in property <string> text;
    in property <bool> accent: false;
    callback clicked();

    height: 36px;
    min-width: 122px;
    border-radius: 4px;
    border-width: accent ? 0px : 2px;
    border-color: Theme.border.with-alpha(64%);
    background: accent ? (touch.has-hover ? Theme.accent.darker(8%) : Theme.accent) : (touch.has-hover ? Theme.surface : transparent);

    Text {
        width: 100%;
        height: 100%;
        text: root.text;
        color: accent ? Theme.bg : Theme.label;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

    export component SettingsWindow inherits Window {
    title: Tr.settings-window-title;
    icon: @image-url("../../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 1180px;
    preferred-height: 820px;
    default-font-family: "Miranda Sans";
    default-font-size: 14px;

    in-out property <bool> always-on-top-setting: false;
    in-out property <bool> animate-transitions-setting: true;
    in-out property <bool> minimize-to-tray-setting: true;
    in-out property <bool> close-to-tray-setting: true;
    in-out property <bool> preserve-aspect-ratio-setting: false;
    in-out property <bool> hide-on-select-setting: true;
    in-out property <bool> show-toolbar-setting: true;
    in-out property <bool> show-info-setting: true;
    in-out property <bool> start-in-tray-setting: false;
    in-out property <bool> run-at-startup-setting: false;
    in-out property <bool> locked-layout-setting: false;
    in-out property <bool> lock-cell-resize-setting: false;
    in-out property <bool> show-app-icons-setting: true;
    in property <bool> hide-on-select-enabled: true;
    in property <bool> default-layout-enabled: true;
    in-out property <int> language-index: 0;
    in-out property <int> refresh-index: 1;
    in-out property <int> refresh-performance-mode-index: 1;
    in-out property <int> layout-index: 0;
    in-out property <int> toolbar-position-index: 1;
    in property <[string]> theme-options: ["Classic Panopticon"];
    in property <[ThemePreviewData]> theme-preview-model: [];
    in-out property <int> theme-index: 0;
    in property <[string]> monitor-filter-options: [Tr.all-monitors-label];
    in-out property <int> monitor-filter-index: 0;
    in property <[string]> tag-filter-options: [Tr.all-tags-label];
    in-out property <int> tag-filter-index: 0;
    in property <[string]> app-filter-options: [Tr.all-apps-label];
    in-out property <int> app-filter-index: 0;
    in property <[string]> app-rules-options: ["Select application rule…"];
    in-out property <int> app-rules-index: 0;
    in-out property <string> app-rules-search: "";
    in-out property <int> app-rules-filter-index: 0;
    in property <bool> app-rules-has-selection: false;
    in property <string> app-rules-selected-app-label: "";
    in-out property <bool> app-rules-hidden: false;
    in-out property <bool> app-rules-preserve-aspect: false;
    in-out property <bool> app-rules-hide-on-select: false;
    in-out property <int> app-rules-refresh-mode-index: 0;
    in-out property <int> app-rules-refresh-interval-ms: 5000;
    in-out property <string> app-rules-tags: "";
    in property <[string]> app-rules-tag-chips: [];
    in-out property <string> app-rules-tag-input: "";
    in-out property <string> app-rules-color-hex: "";
    in property <bool> app-rules-can-clear-unused: false;
    in property <string> app-rules-unused-summary: "";
    in property <[string]> hidden-app-options: [Tr.no-hidden-label];
    in-out property <int> hidden-app-index: 0;
    in property <bool> can-restore-hidden: false;
    in property <string> hidden-apps-summary: Tr.no-hidden-label;
    in property <string> current-profile-label: "default";
    in-out property <string> profile-name: "";
    in-out property <string> profile-display-name: "";
    in-out property <string> profile-description: "";
    in property <string> known-profiles-label: Tr.no-saved-profiles-label;
    in property <string> app-version-text: "";
    in property <string> update-status-text: "";
    in property <bool> update-check-running: false;
    in property <[string]> available-profile-options: [Tr.default-profile-label];
    in-out property <int> available-profile-index: 0;
    in property <string> selected-profile-name: "default";
    in property <bool> selected-profile-is-default: true;
    in property <string> selected-profile-updated-at: "";
    in property <string> selected-profile-created-at: "";
    in-out property <color> bg-preview-color: Theme.accent;
    in-out property <color> theme-preview-color: Theme.accent;
    in-out property <string> bg-color-hex: "181513";
    in-out property <int> bg-red-value: 24;
    in-out property <int> bg-green-value: 21;
    in-out property <int> bg-blue-value: 19;
    in-out property <string> theme-accent-hex: "";
    in property <string> theme-accent-placeholder: "";
    in property <color> theme-accent-preview-color: Theme.accent;
    in-out property <string> theme-surface-hex: "";
    in property <string> theme-surface-placeholder: "";
    in property <color> theme-surface-preview-color: Theme.surface;
    in-out property <string> theme-card-hex: "";
    in property <string> theme-card-placeholder: "";
    in property <color> theme-card-preview-color: Theme.card_bg;
    in-out property <string> theme-text-hex: "";
    in property <string> theme-text-placeholder: "";
    in property <color> theme-text-preview-color: Theme.text;
    in-out property <string> theme-muted-hex: "";
    in property <string> theme-muted-placeholder: "";
    in property <color> theme-muted-preview-color: Theme.muted;
    in-out property <string> theme-border-hex: "";
    in property <string> theme-border-placeholder: "";
    in property <color> theme-border-preview-color: Theme.border;
    in-out property <string> bg-image-path: "";
    in-out property <image> bg-image-preview;
    in-out property <int> bg-image-fit-index: 0;
    in-out property <int> bg-image-opacity-value: 25;
    in-out property <int> fixed-width-value: 0;
    in-out property <int> fixed-height-value: 0;
    in-out property <int> thumbnail-render-scale-value: 100;
    in-out property <int> dock-edge-index: 0;
    in-out property <int> dock-column-thickness-value: 0;
    in-out property <int> dock-row-thickness-value: 0;
    in-out property <int> group-windows-index: 0;
    in-out property <string> shortcut-layout-grid: "1";
    in-out property <string> shortcut-layout-mosaic: "2";
    in-out property <string> shortcut-layout-bento: "3";
    in-out property <string> shortcut-layout-fibonacci: "4";
    in-out property <string> shortcut-layout-columns: "5";
    in-out property <string> shortcut-layout-row: "6";
    in-out property <string> shortcut-layout-column: "7";
    in-out property <string> shortcut-reset-layout: "0";
    in-out property <string> shortcut-cycle-layout: "Tab";
    in-out property <string> shortcut-cycle-theme: "T";
    in-out property <string> shortcut-toggle-animations: "A";
    in-out property <string> shortcut-toggle-toolbar: "H";
    in-out property <string> shortcut-toggle-window-info: "I";
    in-out property <string> shortcut-toggle-always-on-top: "P";
    in-out property <string> shortcut-open-settings: "O";
    in-out property <string> shortcut-open-menu: "M";
    in-out property <string> shortcut-open-command-palette: "K";
    in-out property <string> shortcut-global-activate: "Ctrl+Alt+P";
    in-out property <string> shortcut-refresh-now: "R";
    in-out property <string> shortcut-exit-app: "Esc";
    in-out property <bool> alt-toolbar-shortcut-enabled: true;
    in property <bool> has-shortcut-conflicts: false;
    in property <string> shortcut-conflict-summary: "";
    in property <string> shortcut-conflict-detail: "";
    in-out property <bool> suspend-live-apply: false;

    in-out property <int> current-page: 0;
    property <bool> dock-mode-active: root.dock-edge-index != 0;
    property <bool> dock-column-mode: root.dock-edge-index == 1 || root.dock-edge-index == 2;

    callback apply();
    callback request-live-apply();
    callback save-profile();
    callback load-selected-profile();
    callback open-profile-instance();
    callback profile-selection-changed();
    callback duplicate-selected-profile();
    callback rename-selected-profile();
    callback delete-selected-profile();
    callback open-about();
    callback reset-to-defaults();
    callback refresh-now();
    callback check-updates-now();
    callback restore-hidden-selected();
    callback restore-hidden-all();
    callback app-rules-select-app();
    callback app-rules-apply-selected();
    callback app-rules-reset-selected();
    callback app-rules-refresh-list();
    callback app-rules-clear-unused();
    callback app-rules-add-tag();
    callback app-rules-remove-tag(string);
    callback app-rules-apply-tag-suggestion(string);
    callback browse-background-image();
    callback clear-background-image();
    callback apply-bg-color-hex(string);
    callback apply-bg-color-rgb(int, int, int);
    callback key-pressed(/* key */ string, /* shift_pressed */ bool) -> bool;
    callback closed();

    request-live-apply => {
        if (!root.suspend-live-apply) {
            root.apply();
        }
    }

    changed always-on-top-setting => {
        root.request-live-apply();
    }
    changed animate-transitions-setting => {
        root.request-live-apply();
    }
    changed minimize-to-tray-setting => {
        root.request-live-apply();
    }
    changed close-to-tray-setting => {
        root.request-live-apply();
    }
    changed preserve-aspect-ratio-setting => {
        root.request-live-apply();
    }
    changed hide-on-select-setting => {
        root.request-live-apply();
    }
    changed show-toolbar-setting => {
        root.request-live-apply();
    }
    changed show-info-setting => {
        root.request-live-apply();
    }
    changed start-in-tray-setting => {
        root.request-live-apply();
    }
    changed run-at-startup-setting => {
        root.request-live-apply();
    }
    changed locked-layout-setting => {
        root.request-live-apply();
    }
    changed lock-cell-resize-setting => {
        root.request-live-apply();
    }
    changed show-app-icons-setting => {
        root.request-live-apply();
    }
    changed language-index => {
        root.request-live-apply();
    }
    changed refresh-index => {
        root.request-live-apply();
    }
    changed refresh-performance-mode-index => {
        root.request-live-apply();
    }
    changed layout-index => {
        root.request-live-apply();
    }
    changed toolbar-position-index => {
        root.request-live-apply();
    }
    changed theme-index => {
        root.request-live-apply();
    }
    changed monitor-filter-index => {
        root.request-live-apply();
    }
    changed tag-filter-index => {
        root.request-live-apply();
    }
    changed app-filter-index => {
        root.request-live-apply();
    }
    changed available-profile-index => {
        if (!root.suspend-live-apply) {
            root.profile-selection-changed();
        }
    }
    changed app-rules-index => {
        if (!root.suspend-live-apply) {
            root.app-rules-select-app();
        }
    }
    changed app-rules-search => {
        if (!root.suspend-live-apply) {
            root.app-rules-refresh-list();
        }
    }
    changed app-rules-filter-index => {
        if (!root.suspend-live-apply) {
            root.app-rules-refresh-list();
        }
    }
    changed bg-image-fit-index => {
        root.request-live-apply();
    }
    changed bg-image-opacity-value => {
        root.request-live-apply();
    }
    changed fixed-width-value => {
        root.request-live-apply();
    }
    changed fixed-height-value => {
        root.request-live-apply();
    }
    changed thumbnail-render-scale-value => {
        root.request-live-apply();
    }
    changed dock-edge-index => {
        root.request-live-apply();
    }
    changed dock-column-thickness-value => {
        root.request-live-apply();
    }
    changed dock-row-thickness-value => {
        root.request-live-apply();
    }
    changed group-windows-index => {
        root.request-live-apply();
    }
    changed alt-toolbar-shortcut-enabled => {
        root.request-live-apply();
    }

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 45px;
            background: Theme.bg;

            HorizontalLayout {
                padding-left: 24px;
                padding-right: 24px;
                padding-top: 0px;
                padding-bottom: 12px;
                alignment: space-between;

                VerticalLayout {
                    spacing: 3px;
                    alignment: center;
                    padding-top: 7px;

                    Text {
                        text: Tr.settings-title;
                        color: Theme.text;
                        font-size: 24px;
                        font-weight: 400;
                    }
                }

                Rectangle {
                    width: 170px;
                    height: 42px;
                    border-radius: 4px;
                    border-width: 2px;

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 8px;
                        padding-bottom: 8px;
                        spacing: 10px;

                        Rectangle {
                            width: 3px;
                            height: 28px;
                            border-radius: 2px;
                            background: Theme.accent.with-alpha(50%);
                        }

                        VerticalLayout {
                            spacing: 0px;
                            alignment: start;
                            padding-top: 0px;

                            Text {
                                text: Tr.settings-profile-badge;
                                color: Theme.muted;
                                font-size: 10px;
                            }

                            Text {
                                text: root.current-profile-label;
                                color: Theme.text;
                                font-size: 13px;
                                font-weight: 400;
                                overflow: elide;
                            }
                        }
                    }

                    profile-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => {
                            root.current-page = 3;
                        }
                    }
                }
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            visible: true;

            Rectangle {
                width: 250px;
                background: Theme.bg;

                VerticalLayout {
                    padding: 10px;
                    spacing: 6px;

                    SidebarItem {
                        label: Tr.settings-nav-behaviour-display-title;
                        subtext: Tr.settings-nav-behaviour-display-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-display.svg");
                        active: root.current-page == 0;
                        clicked => {
                            root.current-page = 0;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-filters-title;
                        subtext: Tr.settings-nav-filters-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-filter.svg");
                        active: root.current-page == 1;
                        clicked => {
                            root.current-page = 1;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-theme-background-title;
                        subtext: Tr.settings-nav-theme-background-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-theme.svg");
                        active: root.current-page == 2;
                        clicked => {
                            root.current-page = 2;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-profiles-title;
                        subtext: Tr.settings-nav-profiles-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-profile.svg");
                        active: root.current-page == 3;
                        clicked => {
                            root.current-page = 3;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-shortcuts-title;
                        subtext: Tr.settings-nav-shortcuts-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                        active: root.current-page == 4;
                        clicked => {
                            root.current-page = 4;
                        }
                    }

                    SidebarItem {
                        label: Tr.settings-nav-advanced-title;
                        subtext: Tr.settings-nav-advanced-subtitle;
                        icon: @image-url("../../assets/ui-icons/section-advanced.svg");
                        active: root.current-page == 5;
                        clicked => {
                            root.current-page = 5;
                        }
                    }

                    VerticalLayout {
                        alignment: LayoutAlignment.end;
                        vertical-stretch: 0;
                        spacing: 10px;

                        Image {
                            source: @image-url("../../assets/mascot.svg");
                            vertical-alignment: ImageVerticalAlignment.bottom;
                            vertical-tiling: ImageTiling.none;
                            width: 190px;
                            height: 270px;
                            horizontal-alignment: ImageHorizontalAlignment.center;
                            horizontal-tiling: ImageTiling.none;
                            image-fit: ImageFit.contain;
                        }

                        Text {
                            text: Tr.settings-version-label + " " + root.app-version-text;
                            color: Theme.muted;
                            font-italic: true;
                            font-size: 12px;
                            height: 33px;
                            horizontal-alignment: TextHorizontalAlignment.center;
                            opacity: 0.4;
                            vertical-alignment: TextVerticalAlignment.center;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            Rectangle {
                width: 1px;
                background: Theme.border.with-alpha(60%);
            }

            Rectangle {
                width: 1px;
                background: Theme.border.with-alpha(30%);
            }

            Rectangle {
                width: 1px;
                background: Theme.border.with-alpha(10%);
            }

            ScrollView {
                has-focus: true;
                horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                // Lock the scrollable viewport to the visible width so that
                // children using horizontal-stretch do not create a feedback
                // cycle between their preferred width and the viewport width.
                viewport-width: self.width;

                VerticalLayout {
                    width: parent.width;
                    padding-left: 25px;
                    padding-right: 25px;
                    padding-top: 0px;
                    spacing: 10px;

                    if root.current-page == 0: VerticalLayout {

                        spacing: 12px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-display.svg");
                            title: Tr.settings-page-behaviour-display-title;
                            subtitle: Tr.settings-page-behaviour-display-subtitle;
                        }

                        SectionCard {
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                title: Tr.settings-section-behaviour-title;
                                helper: Tr.settings-section-behaviour-helper;
                            }

                            ToggleSettingCard {
                                enabled: true;
                                icon: @image-url("../../assets/ui-icons/option-always-on-top.svg");
                                title: Tr.settings-option-always-on-top-title;
                                description: Tr.settings-option-always-on-top-description;
                                checked <=> root.always-on-top-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-animate.svg");
                                title: Tr.settings-option-animate-transitions-title;
                                description: Tr.settings-option-animate-transitions-description;
                                checked <=> root.animate-transitions-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-minimize-tray.svg");
                                title: Tr.settings-option-minimize-to-tray-title;
                                description: Tr.settings-option-minimize-to-tray-description;
                                checked <=> root.minimize-to-tray-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-close-tray.svg");
                                title: Tr.settings-option-close-to-tray-title;
                                description: Tr.settings-option-close-to-tray-description;
                                checked <=> root.close-to-tray-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-aspect-ratio.svg");
                                title: Tr.settings-option-preserve-aspect-ratio-title;
                                description: Tr.settings-option-preserve-aspect-ratio-description;
                                checked <=> root.preserve-aspect-ratio-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                                title: Tr.settings-option-hide-on-select-title;
                                description: root.hide-on-select-enabled ? Tr.settings-option-hide-on-select-description : Tr.dock-mode-hint;
                                checked <=> root.hide-on-select-setting;
                                enabled: root.hide-on-select-enabled;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-start-hidden.svg");
                                title: Tr.settings-option-start-in-tray-title;
                                description: Tr.settings-option-start-in-tray-description;
                                checked <=> root.start-in-tray-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                title: Tr.settings-option-run-at-startup-title;
                                description: Tr.settings-option-run-at-startup-description;
                                checked <=> root.run-at-startup-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-lock-layout.svg");
                                title: Tr.settings-option-lock-layout-title;
                                description: Tr.settings-option-lock-layout-description;
                                checked <=> root.locked-layout-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-lock-resize.svg");
                                title: Tr.settings-option-lock-cell-resize-title;
                                description: Tr.settings-option-lock-cell-resize-description;
                                checked <=> root.lock-cell-resize-setting;
                            }
                        }

                        SectionCard {
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-visibility.svg");
                                title: Tr.settings-section-display-title;
                                helper: Tr.settings-section-display-helper;
                            }

                            HorizontalLayout {
                                spacing: 0px;

                                SelectSettingPanel {
                                    horizontal-stretch: 1;
                                    combo-width: 150px;
                                    icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                    title: Tr.settings-option-default-layout-title;
                                    options: Tr.layout-options;
                                    selected-index <=> root.layout-index;
                                    enabled: root.default-layout-enabled;
                                }

                                SelectSettingPanel {
                                    horizontal-stretch: 1;
                                    icon: @image-url("../../assets/ui-icons/option-dock.svg");
                                    title: Tr.settings-option-dock-position-title;
                                    options: Tr.dock-options;
                                    selected-index <=> root.dock-edge-index;
                                }
                            }

                            if root.dock-mode-active: InlineWarning {
                                icon: @image-url("../../assets/ui-icons/option-dock.svg");
                                title: Tr.settings-option-dock-position-title;
                                text: Tr.settings-option-default-layout-docked-description;
                            }

                            if root.dock-mode-active: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 12px;

                                    HorizontalLayout {
                                        spacing: 10px;
                                        alignment: space-between;

                                        SectionHeader {
                                            icon: @image-url("../../assets/ui-icons/option-dock.svg");
                                            title: Tr.settings-section-dock-thickness-title;
                                            helper: Tr.settings-section-dock-thickness-helper;
                                        }

                                        StatusPill {
                                            text: root.dock-column-mode ? Tr.layout-column-label : Tr.layout-row-label;
                                        }
                                    }

                                    HorizontalLayout {
                                        spacing: 16px;

                                        Rectangle {
                                            horizontal-stretch: 1;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(64%);
                                            background: root.dock-column-mode ? Theme.accent-soft.with-alpha(32%) : Theme.surface.with-alpha(48%);

                                            VerticalLayout {
                                                padding: 12px;
                                                spacing: 8px;

                                                Text {
                                                    text: Tr.layout-column-label;
                                                    color: Theme.text;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                }

                                                Text {
                                                    text: Tr.settings-width-label;
                                                    color: Theme.muted;
                                                    font-size: 11px;
                                                }

                                                CustomSpinBox {
                                                    height: 34px;
                                                    value <=> root.dock-column-thickness-value;
                                                    minimum: 0;
                                                    maximum: 3840;
                                                }
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(64%);
                                            background: !root.dock-column-mode ? Theme.accent-soft.with-alpha(32%) : Theme.surface.with-alpha(48%);

                                            VerticalLayout {
                                                padding: 12px;
                                                spacing: 8px;

                                                Text {
                                                    text: Tr.layout-row-label;
                                                    color: Theme.text;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                }

                                                Text {
                                                    text: Tr.settings-height-label;
                                                    color: Theme.muted;
                                                    font-size: 11px;
                                                }

                                                CustomSpinBox {
                                                    height: 34px;
                                                    value <=> root.dock-row-thickness-value;
                                                    minimum: 0;
                                                    maximum: 2160;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            if !root.dock-mode-active: Rectangle {
                                background: transparent;

                                VerticalLayout {
                                    spacing: 12px;

                                    SectionHeader {
                                        icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                        title: Tr.settings-section-floating-window-size-title;
                                        helper: Tr.settings-section-floating-window-size-helper;
                                    }

                                    HorizontalLayout {
                                        spacing: 16px;

                                        Rectangle {
                                            horizontal-stretch: 1;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(64%);
                                            background: Theme.surface.with-alpha(48%);

                                            VerticalLayout {
                                                padding: 12px;
                                                spacing: 8px;

                                                Text {
                                                    text: Tr.settings-width-label;
                                                    color: Theme.text;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                }

                                                CustomSpinBox {
                                                    height: 34px;
                                                    value <=> root.fixed-width-value;
                                                    minimum: 0;
                                                    maximum: 3840;
                                                }
                                            }
                                        }

                                        Rectangle {
                                            horizontal-stretch: 1;
                                            border-radius: 12px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(64%);
                                            background: Theme.surface.with-alpha(48%);

                                            VerticalLayout {
                                                padding: 12px;
                                                spacing: 8px;

                                                Text {
                                                    text: Tr.settings-height-label;
                                                    color: Theme.text;
                                                    font-size: 13px;
                                                    font-weight: 700;
                                                }

                                                CustomSpinBox {
                                                    height: 34px;
                                                    value <=> root.fixed-height-value;
                                                    minimum: 0;
                                                    maximum: 2160;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            SettingRow {
                                icon: @image-url("../../assets/ui-icons/option-image-fit.svg");
                                title: Tr.settings-option-thumbnail-render-scale-title;
                                description: Tr.settings-option-thumbnail-render-scale-description;

                                CustomComboBox {
                                    width: 140px;
                                    height: 34px;
                                    options: ["25%", "50%", "75%", "100%"];
                                    selected-index: root.thumbnail-render-scale-value == 25 ? 0 : root.thumbnail-render-scale-value == 50 ? 1 : root.thumbnail-render-scale-value == 75 ? 2 : 3;
                                    selected(index, _) => {
                                        root.thumbnail-render-scale-value = index == 0 ? 25 : index == 1 ? 50 : index == 2 ? 75 : 100;
                                    }
                                }

                                StatusPill {
                                    text: root.thumbnail-render-scale-value + "%";
                                    subtle: true;
                                }
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                                title: Tr.settings-option-show-toolbar-title;
                                description: Tr.settings-option-show-toolbar-description;
                                checked <=> root.show-toolbar-setting;
                            }

                            SelectSettingPanel {
                                icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                                title: Tr.settings-option-toolbar-position-title;
                                description: Tr.settings-option-toolbar-position-description;
                                options: Tr.toolbar-position-options;
                                selected-index <=> root.toolbar-position-index;
                                enabled: root.show-toolbar-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-window-info.svg");
                                title: Tr.settings-option-show-info-title;
                                description: Tr.settings-option-show-info-description;
                                checked <=> root.show-info-setting;
                            }

                            ToggleSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                                title: Tr.settings-option-show-app-icons-title;
                                description: Tr.settings-option-show-app-icons-description;
                                checked <=> root.show-app-icons-setting;
                            }
                        }
                    }

                    if root.current-page == 1: VerticalLayout {

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-filter.svg");
                            title: Tr.settings-page-filters-title;
                            subtitle: Tr.settings-page-filters-subtitle;
                        }

                        HorizontalLayout {
                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-monitor.svg");
                                title: Tr.settings-option-monitor-filter-title;
                                description: Tr.settings-option-monitor-filter-description;
                                options: root.monitor-filter-options;
                                selected-index <=> root.monitor-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-tag.svg");
                                title: Tr.settings-option-tag-filter-title;
                                description: Tr.settings-option-tag-filter-description;
                                options: root.tag-filter-options;
                                selected-index <=> root.tag-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                                title: Tr.settings-option-app-filter-title;
                                description: Tr.settings-option-app-filter-description;
                                options: root.app-filter-options;
                                selected-index <=> root.app-filter-index;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-group.svg");
                                title: Tr.settings-option-group-windows-title;
                                description: Tr.settings-option-group-windows-description;
                                options: Tr.group-options;
                                selected-index <=> root.group-windows-index;
                            }
                        }

                        SectionCard {
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                                title: Tr.settings-section-hidden-apps-title;
                                helper: Tr.settings-section-hidden-apps-helper;
                            }

                            Text {
                                text: root.hidden-apps-summary;
                                color: Theme.label;
                                font-size: 13px;
                                wrap: word-wrap;
                            }

                            CustomComboBox {
                                height: 40px;
                                options: root.hidden-app-options;
                                selected-index <=> root.hidden-app-index;
                                enabled: root.can-restore-hidden;
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                CustomButton {
                                    height: 30px;
                                    text: Tr.action-restore-selected;
                                    enabled: root.can-restore-hidden;
                                    clicked => {
                                        root.restore-hidden-selected();
                                    }
                                }

                                CustomButton {
                                    height: 30px;
                                    text: Tr.action-restore-all;
                                    enabled: root.can-restore-hidden;
                                    clicked => {
                                        root.restore-hidden-all();
                                    }
                                }
                            }
                        }

                        SectionCard {
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                title: Tr.settings-section-app-rules-title;
                                helper: Tr.settings-section-app-rules-helper;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                                title: Tr.settings-option-app-rules-app-title;
                                description: Tr.settings-option-app-rules-app-description;
                                options: root.app-rules-options;
                                selected-index <=> root.app-rules-index;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                CustomLineEdit {
                                    horizontal-stretch: 1;
                                    height: 34px;
                                    text <=> root.app-rules-search;
                                    placeholder: Tr.settings-option-app-rules-search-placeholder;
                                }

                                CustomComboBox {
                                    width: 200px;
                                    height: 34px;
                                    options: Tr.settings-app-rules-filter-options;
                                    selected-index <=> root.app-rules-filter-index;
                                }
                            }

                            InlineWarning {
                                subtle: true;
                                icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                title: Tr.settings-app-rules-clear-unused-button;
                                text: root.app-rules-unused-summary;
                            }

                            if root.app-rules-has-selection: VerticalLayout {
                                spacing: 10px;

                                SettingRow {
                                    icon: @image-url("../../assets/ui-icons/option-app-icon.svg");
                                    title: Tr.settings-app-rules-active-title;
                                    description: root.app-rules-selected-app-label;

                                    StatusPill {
                                        text: Tr.settings-app-rules-active-badge;
                                        subtle: true;
                                    }
                                }

                                ToggleSettingCard {
                                    icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                                    title: Tr.settings-app-rules-hidden-title;
                                    description: Tr.settings-app-rules-hidden-description;
                                    checked <=> root.app-rules-hidden;
                                }

                                ToggleSettingCard {
                                    icon: @image-url("../../assets/ui-icons/option-aspect-ratio.svg");
                                    title: Tr.settings-app-rules-preserve-aspect-title;
                                    description: Tr.settings-app-rules-preserve-aspect-description;
                                    checked <=> root.app-rules-preserve-aspect;
                                }

                                ToggleSettingCard {
                                    icon: @image-url("../../assets/ui-icons/option-hide-select.svg");
                                    title: Tr.settings-app-rules-hide-on-select-title;
                                    description: Tr.settings-app-rules-hide-on-select-description;
                                    checked <=> root.app-rules-hide-on-select;
                                }

                                SettingRow {
                                    icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                    title: Tr.settings-app-rules-refresh-mode-title;
                                    description: Tr.settings-app-rules-refresh-mode-description;

                                    CustomComboBox {
                                        width: 150px;
                                        height: 34px;
                                        options: Tr.settings-app-rules-refresh-options;
                                        selected-index <=> root.app-rules-refresh-mode-index;
                                    }
                                }

                                if root.app-rules-refresh-mode-index == 2: SettingRow {
                                    icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                    title: Tr.settings-app-rules-interval-title;
                                    description: Tr.settings-app-rules-interval-description;

                                    CustomSpinBox {
                                        width: 130px;
                                        height: 34px;
                                        value <=> root.app-rules-refresh-interval-ms;
                                        minimum: 500;
                                        maximum: 60000;
                                    }
                                }

                                Rectangle {
                                    border-radius: 8px;
                                    border-width: 1px;
                                    border-color: Theme.border.with-alpha(48%);
                                    background: Theme.surface.with-alpha(32%);

                                    VerticalLayout {
                                        padding: 10px;
                                        spacing: 8px;

                                        SettingRow {
                                            icon: @image-url("../../assets/ui-icons/option-tag.svg");
                                            title: Tr.settings-app-rules-tags-title;
                                            description: Tr.settings-app-rules-tags-description;

                                            StatusPill {
                                                text: root.app-rules-tag-chips.length + " tags";
                                                subtle: true;
                                            }
                                        }

                                        InlineWarning {
                                            subtle: true;
                                            icon: @image-url("../../assets/ui-icons/option-tag.svg");
                                            title: Tr.settings-app-rules-tag-suggestions-title;
                                            text: Tr.settings-app-rules-tag-remove-hint;
                                        }

                                        ScrollView {
                                            width: 100%;
                                            height: 44px;
                                            horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                                            viewport-width: self.width;

                                            HorizontalLayout {
                                                width: max(parent.width, root.app-rules-tag-chips.length * 110px);
                                                spacing: 8px;
                                                padding-top: 6px;
                                                padding-bottom: 6px;

                                                for tag in root.app-rules-tag-chips: Rectangle {
                                                    min-width: 82px;
                                                    height: 30px;
                                                    border-radius: 15px;
                                                    border-width: 1px;
                                                    border-color: Theme.accent.with-alpha(60%);
                                                    background: Theme.accent-soft.with-alpha(44%);

                                                    HorizontalLayout {
                                                        padding-left: 10px;
                                                        padding-right: 10px;
                                                        spacing: 6px;

                                                        Text {
                                                            text: tag;
                                                            color: Theme.text;
                                                            font-size: 11px;
                                                            font-weight: 600;
                                                            vertical-alignment: center;
                                                        }

                                                        Text {
                                                            text: "×";
                                                            color: Theme.muted;
                                                            font-size: 11px;
                                                            font-weight: 700;
                                                            vertical-alignment: center;
                                                        }
                                                    }

                                                    TouchArea {
                                                        mouse-cursor: pointer;
                                                        clicked => {
                                                            root.app-rules-remove-tag(tag);
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 8px;

                                            CustomLineEdit {
                                                horizontal-stretch: 1;
                                                height: 32px;
                                                text <=> root.app-rules-tag-input;
                                                placeholder: Tr.settings-app-rules-tags-placeholder;
                                                accepted(_) => {
                                                    root.app-rules-add-tag();
                                                }
                                            }

                                            CustomButton {
                                                height: 32px;
                                                text: Tr.settings-app-rules-tag-add-button;
                                                clicked => {
                                                    root.app-rules-add-tag();
                                                }
                                            }
                                        }

                                        HorizontalLayout {
                                            spacing: 8px;

                                            for suggestion in Tr.settings-app-rules-tag-suggestion-options: CustomButton {
                                                height: 28px;
                                                text: suggestion;
                                                clicked => {
                                                    root.app-rules-apply-tag-suggestion(suggestion);
                                                }
                                            }
                                        }
                                    }
                                }

                                TextFieldSettingCard {
                                    icon: @image-url("../../assets/ui-icons/option-palette.svg");
                                    title: Tr.settings-app-rules-color-title;
                                    description: Tr.settings-app-rules-color-description;
                                    value <=> root.app-rules-color-hex;
                                    placeholder: Tr.settings-app-rules-color-placeholder;
                                }

                                HorizontalLayout {
                                    spacing: 10px;

                                    CustomButton {
                                        height: 34px;
                                        text: Tr.settings-app-rules-apply-button;
                                        clicked => {
                                            root.app-rules-apply-selected();
                                        }
                                    }

                                    CustomButton {
                                        height: 34px;
                                        text: Tr.settings-app-rules-reset-button;
                                        clicked => {
                                            root.app-rules-reset-selected();
                                        }
                                    }

                                    CustomButton {
                                        height: 34px;
                                        text: Tr.settings-app-rules-clear-unused-button;
                                        enabled: root.app-rules-can-clear-unused;
                                        clicked => {
                                            root.app-rules-clear-unused();
                                        }
                                    }
                                }
                            }

                            if !root.app-rules-has-selection: Text {
                                text: Tr.settings-app-rules-no-selection;
                                color: Theme.muted;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    if root.current-page == 2: VerticalLayout {
                        spacing: 12px;

                        PageHeader {
                            icon: @image-url("../../assets/ui-icons/section-theme.svg");
                            title: Tr.settings-page-theme-background-title;
                            subtitle: Tr.settings-page-theme-background-subtitle;
                        }

                        HorizontalLayout {
                            width: 100%;
                            spacing: 10px;
                            alignment: start;

                            Rectangle {
                                horizontal-stretch: 5;
                                min-width: 300px;
                                height: 400px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(10%);
                                background: Theme.card_bg.with-alpha(92%);
                                clip: true;

                                ScrollView {
                                    width: parent.width;
                                    height: parent.height;
                                    viewport-width: self.width;

                                    VerticalLayout {
                                        width: parent.width;
                                        padding: 10px;
                                        spacing: 6px;

                                        SectionTitle {
                                            icon: @image-url("../../assets/ui-icons/option-palette.svg");
                                            text: Tr.settings-section-theme-colours-title;
                                            helper: Tr.settings-theme-override-hint;
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-option-custom-canvas-colour-title;
                                            value <=> root.bg-color-hex;
                                            placeholder: "181513";
                                            preview-color: root.bg-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply-bg-color-hex(root.bg-color-hex);
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-accent-label;
                                            value <=> root.theme-accent-hex;
                                            placeholder: root.theme-accent-placeholder;
                                            preview-color: root.theme-accent-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-surface-label;
                                            value <=> root.theme-surface-hex;
                                            placeholder: root.theme-surface-placeholder;
                                            preview-color: root.theme-surface-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-card-label;
                                            value <=> root.theme-card-hex;
                                            placeholder: root.theme-card-placeholder;
                                            preview-color: root.theme-card-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-text-label;
                                            value <=> root.theme-text-hex;
                                            placeholder: root.theme-text-placeholder;
                                            preview-color: root.theme-text-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-muted-label;
                                            value <=> root.theme-muted-hex;
                                            placeholder: root.theme-muted-placeholder;
                                            preview-color: root.theme-muted-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }

                                        ThemeColorSettingRow {
                                            label: Tr.settings-theme-border-label;
                                            value <=> root.theme-border-hex;
                                            placeholder: root.theme-border-placeholder;
                                            preview-color: root.theme-border-preview-color;
                                            committed => {
                                                if !root.suspend-live-apply {
                                                    root.apply();
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 5;
                                min-width: 300px;
                                height: 400px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(10%);
                                background: Theme.card_bg.with-alpha(92%);
                                clip: true;

                                ScrollView {
                                    width: parent.width;
                                    height: parent.height;
                                    viewport-width: self.width;

                                    VerticalLayout {
                                        width: parent.width;
                                        padding: 14px;
                                        spacing: 10px;

                                        SectionTitle {
                                            icon: @image-url("../../assets/ui-icons/option-image.svg");
                                            text: Tr.settings-section-background-image-title;
                                            helper: Tr.settings-section-background-image-helper;
                                        }

                                        HorizontalLayout {
                                            spacing: 10px;

                                            CustomButton {
                                                height: 40px;
                                                text: Tr.action-browse-image;
                                                clicked => {
                                                    root.browse-background-image();
                                                }
                                            }

                                            CustomButton {
                                                height: 40px;
                                                text: Tr.action-clear-image;
                                                clicked => {
                                                    root.clear-background-image();
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-file-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                            }

                                            CustomLineEdit {
                                                text <=> root.bg-image-path;
                                                height: 32px;
                                                placeholder: "C:/Users/.../background.png";
                                                accepted(_) => {
                                                    if !root.suspend-live-apply {
                                                        root.apply();
                                                    }
                                                }
                                                focus-lost => {
                                                    if !root.suspend-live-apply {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-fit-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                            }

                                            CustomComboBox {
                                                width: 180px;
                                                height: 32px;
                                                options: Tr.image-fit-options;
                                                selected-index <=> root.bg-image-fit-index;
                                            }
                                        }

                                        VerticalLayout {
                                            spacing: 6px;

                                            Text {
                                                text: Tr.settings-option-image-opacity-title;
                                                color: Theme.label;
                                                font-size: 12px;
                                                height: 20px;
                                            }

                                            HorizontalLayout {
                                                spacing: 10px;

                                                CustomSlider {
                                                    horizontal-stretch: 1;
                                                    minimum: 0;
                                                    maximum: 100;
                                                    value <=> root.bg-image-opacity-value;
                                                }

                                                CustomSpinBox {
                                                    width: 72px;
                                                    height: 32px;
                                                    minimum: 0;
                                                    maximum: 100;
                                                    value <=> root.bg-image-opacity-value;
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 3;
                                min-width: 240px;
                                height: 400px;
                                border-radius: 4px;
                                border-width: 2px;
                                border-color: Theme.border.with-alpha(10%);
                                background: Theme.card_bg.with-alpha(92%);

                                VerticalLayout {
                                    padding-top: 8px;
                                    padding-left: 14px;
                                    padding-right: 14px;
                                    spacing: 8px;

                                    SectionTitle {
                                        icon: @image-url("../../assets/ui-icons/section-theme.svg");
                                        text: Tr.settings-section-preview-title;
                                        helper: Tr.settings-section-preview-helper;
                                    }

                                    Rectangle {
                                        height: 148px;
                                        border-radius: 12px;
                                        background: root.bg-preview-color;
                                        clip: true;

                                        if root.bg-image-preview.width > 0: Image {
                                            width: 100%;
                                            height: 100%;
                                            source: root.bg-image-preview;
                                            image-fit: root.bg-image-fit-index == 1 ? contain : root.bg-image-fit-index == 2 ? fill : root.bg-image-fit-index == 3 ? preserve : cover;
                                            opacity: root.bg-image-opacity-value / 100;
                                        }

                                        Rectangle {
                                            x: 12px;
                                            y: 12px;
                                            width: 68px;
                                            height: 22px;
                                            border-radius: 11px;
                                            background: Theme.panel_bg.with-alpha(84%);

                                            Text {
                                                width: 100%;
                                                height: 100%;
                                                text: root.bg-color-hex;
                                                color: Theme.text;
                                                font-size: 10px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        themes-card-rect := Rectangle {
                            width: 100%;
                            height: 300px;
                            border-radius: 4px;
                            border-width: 2px;
                            border-color: Theme.border.with-alpha(10%);
                            background: Theme.card_bg.with-alpha(92%);
                            clip: true;

                            VerticalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding: 14px;
                                spacing: 10px;

                                SectionTitle {
                                    icon: @image-url("../../assets/ui-icons/section-theme.svg");
                                    text: Tr.settings-section-theme-grid-title;
                                    helper: Tr.settings-section-theme-grid-helper;
                                }

                                theme-list-scroll := ScrollView {
                                    width: parent.width;
                                    // Keep this explicit to avoid ScrollView taking content
                                    // height and swallowing internal scrolling.
                                    height: max(themes-card-rect.height - 28px - 42px - 10px, 120px);

                                    theme-grid-content := Rectangle {
                                        x: 12px;
                                        y: 12px;
                                        width: max(theme-list-scroll.width - 24px, 220px);
                                        property <length> grid-gap: 16px;
                                        property <length> card-height: 92px;
                                        property <int> column-count: self.width >= 840px ? 3 : self.width >= 560px ? 2 : 1;
                                        property <length> card-width: self.column-count == 1 ? self.width : self.column-count == 2 ? max((self.width - self.grid-gap) / 2, 220px) : max((self.width - (self.grid-gap * 2)) / 3, 220px);
                                        property <int> row-count: max((root.theme-preview-model.length + self.column-count - 1) / self.column-count, 1);
                                        height: max((self.row-count * self.card-height) + ((self.row-count - 1) * self.grid-gap), self.card-height);

                                        for theme[index] in root.theme-preview-model: ThemePreviewCard {
                                            property <int> grid-col: Math.mod(index, theme-grid-content.column-count);
                                            property <int> grid-row: index / theme-grid-content.column-count;
                                            x: grid-col * (theme-grid-content.card-width + theme-grid-content.grid-gap);
                                            y: grid-row * (theme-grid-content.card-height + theme-grid-content.grid-gap);
                                            width: theme-grid-content.card-width;
                                            height: theme-grid-content.card-height;
                                            theme: theme;
                                            selected: root.theme-index == theme.index;
                                            picked(idx) => {
                                                root.theme-index = idx;
                                                root.theme-preview-color = theme.accent;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-page == 3: VerticalLayout {

                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 0px;
                    spacing: 10px;

                    PageHeader {
                        icon: @image-url("../../assets/ui-icons/section-profile.svg");
                        title: Tr.settings-page-profiles-title;
                        subtitle: Tr.settings-page-profiles-subtitle;
                    }

                    HorizontalLayout {
                        spacing: 16px;

                        SectionCard {
                            width: 460px;
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                title: Tr.settings-section-load-profile-title;
                                helper: Tr.settings-section-load-profile-helper;
                            }

                            SelectSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                title: Tr.settings-option-available-profile-title;
                                description: Tr.settings-option-available-profile-description;
                                options: root.available-profile-options;
                                selected-index <=> root.available-profile-index;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                CustomButton {
                                    height: 40px;
                                    text: Tr.action-load-profile;
                                    clicked => {
                                        root.load-selected-profile();
                                    }
                                }

                                CustomButton {
                                    text: Tr.open-instance-btn;
                                    clicked => {
                                        root.open-profile-instance();
                                    }
                                }
                            }

                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                title: Tr.settings-section-edit-profile-title;
                                helper: Tr.settings-section-edit-profile-helper;
                            }

                            SettingRow {
                                icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                title: Tr.settings-current-profile-card-title;
                                description: root.current-profile-label;

                                StatusPill {
                                    text: root.current-profile-label;
                                }
                            }

                            TextFieldSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                title: Tr.settings-option-profile-name-title;
                                description: Tr.settings-option-profile-name-description;
                                value <=> root.profile-name;
                                placeholder: "workspace-a";
                            }

                            TextFieldSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                title: "Display name";
                                description: "Friendly name shown in workspace lists.";
                                value <=> root.profile-display-name;
                                placeholder: "Work · Deep focus";
                            }

                            TextFieldSettingCard {
                                icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                title: "Description";
                                description: "Optional note to remember what this workspace is for.";
                                value <=> root.profile-description;
                                placeholder: "Pinned apps + filters for design review sessions";
                            }

                            HorizontalLayout {
                                spacing: 10px;
                                CustomButton {
                                    height: 40px;
                                    text: Tr.save-profile-btn;
                                    clicked => {
                                        root.save-profile();
                                    }
                                }

                                CustomButton {
                                    height: 40px;
                                    text: "Duplicate";
                                    clicked => {
                                        root.duplicate-selected-profile();
                                    }
                                }

                                CustomButton {
                                    height: 40px;
                                    text: "Rename";
                                    enabled: !root.selected-profile-is-default;
                                    clicked => {
                                        root.rename-selected-profile();
                                    }
                                }

                                CustomButton {
                                    height: 40px;
                                    text: "Delete";
                                    enabled: !root.selected-profile-is-default;
                                    clicked => {
                                        root.delete-selected-profile();
                                    }
                                }
                            }
                        }

                        SectionCard {
                            horizontal-stretch: 1;
                            SectionHeader {
                                icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                title: Tr.settings-section-saved-profiles-title;
                                helper: Tr.settings-section-saved-profiles-helper;
                            }

                            Rectangle {
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.surface.with-alpha(34%);
                                height: 220px;
                                clip: true;

                                ScrollView {
                                    width: parent.width;
                                    height: parent.height;
                                    viewport-width: self.width;

                                    VerticalLayout {
                                        width: parent.width;
                                        padding: 8px;
                                        spacing: 6px;

                                        for profile[index] in root.available-profile-options: Rectangle {
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: root.available-profile-index == index ? Theme.accent.with-alpha(56%) : Theme.border.with-alpha(44%);
                                            background: root.available-profile-index == index ? Theme.accent-soft.with-alpha(24%) : profile-row-touch.has-hover ? Theme.surface.with-alpha(52%) : transparent;
                                            min-height: 42px;

                                            HorizontalLayout {
                                                padding-left: 10px;
                                                padding-right: 10px;
                                                padding-top: 8px;
                                                padding-bottom: 8px;
                                                spacing: 10px;
                                                alignment: space-between;

                                                Text {
                                                    text: profile;
                                                    color: Theme.text;
                                                    font-size: 12.5px;
                                                    font-weight: root.available-profile-index == index ? 700 : 500;
                                                    overflow: elide;
                                                    horizontal-stretch: 1;
                                                }

                                                if profile == root.current-profile-label: StatusPill {
                                                    text: "ACTIVE";
                                                }

                                                if profile == "default": StatusPill {
                                                    text: "DEFAULT";
                                                    subtle: true;
                                                }
                                            }

                                            profile-row-touch := TouchArea {
                                                mouse-cursor: pointer;
                                                clicked => {
                                                    root.available-profile-index = index;
                                                    root.profile-selection-changed();
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            InlineWarning {
                                subtle: true;
                                icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                title: Tr.settings-section-saved-profiles-title;
                                text: root.known-profiles-label;
                            }

                            Rectangle {
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.surface.with-alpha(34%);

                                VerticalLayout {
                                    padding: 10px;
                                    spacing: 8px;

                                    Text {
                                        text: "Selected workspace metadata";
                                        color: Theme.accent;
                                        font-size: 12px;
                                        font-weight: 700;
                                    }

                                    SettingRow {
                                        icon: @image-url("../../assets/ui-icons/option-profiles-list.svg");
                                        title: "Workspace";
                                        description: root.selected-profile-name;

                                        if root.selected-profile-is-default: StatusPill {
                                            text: "DEFAULT";
                                            subtle: true;
                                        }
                                    }

                                    SettingRow {
                                        icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                        title: "Display name";
                                        description: root.profile-display-name == "" ? "—" : root.profile-display-name;
                                    }

                                    SettingRow {
                                        icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                                        title: "Description";
                                        description: root.profile-description == "" ? "—" : root.profile-description;
                                    }

                                    SettingRow {
                                        icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                        title: "Last updated";
                                        description: root.selected-profile-updated-at == "" ? "Not saved yet" : root.selected-profile-updated-at;
                                    }

                                    SettingRow {
                                        icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                        title: "Created";
                                        description: root.selected-profile-created-at == "" ? "Unknown" : root.selected-profile-created-at;
                                    }
                                }
                            }
                        }
                    }

                    InlineWarning {
                        width: 440px;
                        subtle: true;
                        icon: @image-url("../../assets/ui-icons/option-profile-edit.svg");
                        title: Tr.settings-tips-title;
                        text: Tr.settings-tips-body;
                    }
                }

                if root.current-page == 4: VerticalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 0px;
                    spacing: 12px;

                    PageHeader {
                        icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                        title: Tr.settings-page-shortcuts-title;
                        subtitle: Tr.settings-page-shortcuts-subtitle;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: space-between;

                        CustomLineEdit {
                            horizontal-stretch: 1;
                            height: 34px;
                            placeholder: "Search shortcuts...";
                            enabled: true;
                        }

                        Rectangle {
                            width: 240px;
                            height: 34px;
                            border-radius: 4px;
                            border-width: 2px;
                            border-color: Theme.border.with-alpha(50%);
                            background: Theme.surface.with-alpha(48%);

                            HorizontalLayout {
                                padding: 6px;
                                spacing: 8px;

                                CustomCheckBox {
                                    width: 20px;
                                    height: 20px;
                                    checked <=> root.alt-toolbar-shortcut-enabled;
                                }

                                Text {
                                    text: "Use Alt as quick status bar toggle";
                                    color: Theme.text;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                        }
                    }

                    if root.has-shortcut-conflicts: InlineWarning {
                        icon: @image-url("../../assets/ui-icons/section-keyboard.svg");
                        title: root.shortcut-conflict-summary;
                        text: root.shortcut-conflict-detail;
                    }

                    ScrollView {
                        width: 100%;
                        vertical-stretch: 1;
                        horizontal-scrollbar-policy: ScrollBarPolicy.as-needed;
                        viewport-width: self.width;

                        VerticalLayout {
                            width: parent.width;
                            spacing: 14px;
                            padding: 0px;

                            Rectangle {
                                border-radius: 12px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.card-bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    Text {
                                        text: "GLOBAL SHORTCUTS";
                                        color: Theme.accent;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        KeyFieldSettingCard {
                                            col: 0;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                            title: Tr.settings-shortcut-global-activate-title;
                                            description: "";
                                            value <=> root.shortcut-global-activate;
                                            placeholder: "Ctrl+Alt+P";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 1;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-cycle.svg");
                                            title: Tr.settings-shortcut-cycle-layout-title;
                                            description: "";
                                            value <=> root.shortcut-cycle-layout;
                                            placeholder: "Tab";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 2;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-window-info.svg");
                                            title: Tr.settings-shortcut-toggle-window-info-title;
                                            description: "";
                                            value <=> root.shortcut-toggle-window-info;
                                            placeholder: "I";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                border-radius: 12px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.card-bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 12px;

                                    Text {
                                        text: "LAYOUT SELECTION";
                                        color: Theme.accent;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: "Quickly switch between layouts.";
                                        color: Theme.muted;
                                        font-size: 10px;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        Rectangle {
                                            col: 0;
                                            row: 0;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Grid";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-grid;
                                                    placeholder: "1";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            col: 1;
                                            row: 0;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Mosaic";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-mosaic;
                                                    placeholder: "2";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            col: 2;
                                            row: 0;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Bento";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-bento;
                                                    placeholder: "3";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            col: 0;
                                            row: 1;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Fibonacci";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-fibonacci;
                                                    placeholder: "4";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            col: 1;
                                            row: 1;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Columns";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-columns;
                                                    placeholder: "5";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            col: 2;
                                            row: 1;
                                            height: 80px;
                                            border-radius: 8px;
                                            border-width: 1px;
                                            border-color: Theme.border.with-alpha(48%);
                                            background: Theme.surface.with-alpha(38%);

                                            VerticalLayout {
                                                padding: 10px;
                                                spacing: 6px;

                                                Text {
                                                    text: "Rows";
                                                    color: Theme.text;
                                                    font-size: 12px;
                                                    font-weight: 700;
                                                }

                                                CustomLineEdit {
                                                    height: 28px;
                                                    text <=> root.shortcut-layout-row;
                                                    placeholder: "6";
                                                    accepted(_) => {
                                                        root.apply();
                                                    }
                                                    focus-lost => {
                                                        root.apply();
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                border-radius: 12px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.card-bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 10px;

                                    Text {
                                        text: "LAYOUT CONTROLS";
                                        color: Theme.accent;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: "Additional layout actions and adjustments.";
                                        color: Theme.muted;
                                        font-size: 10px;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        KeyFieldSettingCard {
                                            col: 0;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-layout.svg");
                                            title: Tr.settings-shortcut-layout-column-title;
                                            description: "";
                                            value <=> root.shortcut-layout-column;
                                            placeholder: "7";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 1;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                            title: Tr.settings-shortcut-reset-layout-title;
                                            description: "";
                                            value <=> root.shortcut-reset-layout;
                                            placeholder: "0";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 2;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-cycle.svg");
                                            title: "Cycle layout";
                                            description: "";
                                            value <=> root.shortcut-cycle-layout;
                                            placeholder: "Tab";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }
                                }
                            }

                            Rectangle {
                                border-radius: 12px;
                                border-width: 1px;
                                border-color: Theme.border.with-alpha(48%);
                                background: Theme.card-bg.with-alpha(92%);

                                VerticalLayout {
                                    padding: 14px;
                                    spacing: 12px;

                                    Text {
                                        text: "DASHBOARD ACTIONS";
                                        color: Theme.accent;
                                        font-size: 11px;
                                        font-weight: 700;
                                    }

                                    Text {
                                        text: "Control the dashboard experience.";
                                        color: Theme.muted;
                                        font-size: 10px;
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: Theme.border.with-alpha(30%);
                                    }

                                    Text {
                                        text: "UI TOGGLES";
                                        color: Theme.accent.with-alpha(72%);
                                        font-size: 10px;
                                        font-weight: 600;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        KeyFieldSettingCard {
                                            col: 0;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-show-toolbar.svg");
                                            title: Tr.settings-shortcut-toggle-toolbar-title;
                                            description: "";
                                            value <=> root.shortcut-toggle-toolbar;
                                            placeholder: "H";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 1;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-animate.svg");
                                            title: Tr.settings-shortcut-toggle-animations-title;
                                            description: "";
                                            value <=> root.shortcut-toggle-animations;
                                            placeholder: "A";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 2;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-window-info.svg");
                                            title: Tr.settings-shortcut-toggle-window-info-title;
                                            description: "";
                                            value <=> root.shortcut-toggle-window-info;
                                            placeholder: "I";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: Theme.border.with-alpha(30%);
                                    }

                                    Text {
                                        text: "NAVIGATION";
                                        color: Theme.accent.with-alpha(72%);
                                        font-size: 10px;
                                        font-weight: 600;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        KeyFieldSettingCard {
                                            col: 0;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-settings.svg");
                                            title: Tr.settings-shortcut-open-settings-title;
                                            description: "";
                                            value <=> root.shortcut-open-settings;
                                            placeholder: "O";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 1;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-menu.svg");
                                            title: Tr.settings-shortcut-open-menu-title;
                                            description: "";
                                            value <=> root.shortcut-open-menu;
                                            placeholder: "M";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 2;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-menu.svg");
                                            title: Tr.settings-shortcut-open-command-palette-title;
                                            description: "";
                                            value <=> root.shortcut-open-command-palette;
                                            placeholder: "K";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }

                                    Rectangle {
                                        height: 1px;
                                        background: Theme.border.with-alpha(30%);
                                    }

                                    Text {
                                        text: "SYSTEM";
                                        color: Theme.accent.with-alpha(72%);
                                        font-size: 10px;
                                        font-weight: 600;
                                    }

                                    GridLayout {
                                        spacing: 10px;

                                        KeyFieldSettingCard {
                                            col: 0;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                                            title: Tr.settings-shortcut-refresh-now-title;
                                            description: "";
                                            value <=> root.shortcut-refresh-now;
                                            placeholder: "R";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 1;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-exit.svg");
                                            title: Tr.settings-shortcut-exit-app-title;
                                            description: "";
                                            value <=> root.shortcut-exit-app;
                                            placeholder: "Esc";
                                            committed => {
                                                root.apply();
                                            }
                                        }

                                        KeyFieldSettingCard {
                                            col: 2;
                                            row: 0;
                                            icon: @image-url("../../assets/ui-icons/option-always-on-top.svg");
                                            title: Tr.settings-shortcut-toggle-always-on-top-title;
                                            description: "";
                                            value <=> root.shortcut-toggle-always-on-top;
                                            placeholder: "P";
                                            committed => {
                                                root.apply();
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if root.current-page == 5: VerticalLayout {

                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 0px;
                    spacing: 10px;

                    PageHeader {
                        icon: @image-url("../../assets/ui-icons/section-advanced.svg");
                        title: Tr.settings-page-advanced-title;
                        subtitle: Tr.settings-page-advanced-subtitle;
                    }

                    SectionCard {
                        SectionHeader {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-section-refresh-performance-title;
                            helper: Tr.settings-section-refresh-performance-helper;
                        }

                        SelectSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-option-refresh-performance-mode-title;
                            description: Tr.settings-option-refresh-performance-mode-description;
                            options: Tr.settings-refresh-mode-options;
                            selected-index <=> root.refresh-performance-mode-index;
                        }

                        InlineWarning {
                            subtle: true;
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-refresh-active-mode-title;
                            text: root.refresh-performance-mode-index == 0 ? Tr.settings-refresh-active-mode-realtime : root.refresh-performance-mode-index == 1 ? Tr.settings-refresh-active-mode-balanced : root.refresh-performance-mode-index == 2 ? Tr.settings-refresh-active-mode-battery : Tr.settings-refresh-active-mode-manual;
                        }
                    }

                    SectionCard {
                        SectionHeader {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-option-refresh-interval-title;
                            helper: Tr.settings-option-refresh-interval-description;
                        }

                        SelectSettingCard {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-option-refresh-interval-title;
                            description: Tr.settings-option-refresh-interval-description;
                            options: Tr.settings-refresh-interval-options;
                            selected-index <=> root.refresh-index;
                            enabled: root.refresh-performance-mode-index == 3;
                        }
                    }

                    SectionCard {
                        SectionHeader {
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: Tr.settings-section-manual-refresh-title;
                            helper: Tr.settings-section-manual-refresh-helper;
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            CustomButton {
                                height: 40px;
                                width: 120px;
                                text: Tr.action-refresh-now;
                                clicked => {
                                    root.refresh-now();
                                }
                            }

                            CustomButton {
                                height: 40px;
                                text: Tr.action-check-updates;
                                enabled: !root.update-check-running;
                                clicked => {
                                    root.check-updates-now();
                                }
                            }

                            StatusPill {
                                text: root.update-status-text;
                                subtle: true;
                            }
                        }

                        InlineWarning {
                            subtle: true;
                            icon: @image-url("../../assets/ui-icons/option-refresh.svg");
                            title: root.update-status-text;
                            text: Tr.settings-version-label + " " + root.app-version-text;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 62px;
            background: Theme.bg.with-alpha(30%);

            VerticalLayout {
                Divider {
                    vertical-stretch: 0;
                    height: 2px;
                }

                HorizontalLayout {
                    padding-left: 24px;
                    padding-right: 24px;
                    padding-top: 12px;
                    padding-bottom: 12px;
                    spacing: 10px;
                    alignment: space-between;
                    vertical-stretch: 1;

                    SelectSettingCard {
                        icon: @image-url("../../assets/ui-icons/option-settings.svg");
                        title: Tr.settings-option-language-title;
                        description: Tr.settings-option-language-description;
                        options: Tr.language-options;
                        selected-index <=> root.language-index;
                    }

                    HorizontalLayout {
                        spacing: 12px;
                        FooterButton {
                            text: Tr.action-about;
                            clicked => {
                                root.open-about();
                            }
                        }

                        FooterButton {
                            text: Tr.action-reset-defaults;
                            clicked => {
                                root.reset-to-defaults();
                            }
                        }

                        FooterButton {
                            text: Tr.action-close;
                            clicked => {
                                root.closed();
                            }
                        }
                    }
                }
            }
        }
    }

    forward-focus: key-handler;
    key-handler := FocusScope {
        key-pressed(event) => {
            if root.key-pressed(event.text, event.modifiers.shift) {
                return accept;
            }
            reject
        }
    }
}
