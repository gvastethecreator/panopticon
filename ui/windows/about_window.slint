import { Tr, Theme } from "../common.slint";

component AboutCard inherits Rectangle {
    in property <string> title;
    in property <string> body;

    border-radius: 4px;
    background: Theme.card_bg.with-alpha(92%);

    VerticalLayout {
        padding: 14px;
        spacing: 6px;

        Text {
            text: root.title;
            color: Theme.accent;
            font-size: 12px;
            font-weight: 700;
        }

        Text {
            text: root.body;
            color: Theme.label;
            font-size: 12.5px;
            wrap: word-wrap;
        }
    }
}

component VersionCard inherits Rectangle {
    in property <string> title;
    in property <string> version-text;
    in property <bool> show-update-badge: false;
    in property <string> latest-version-text: "";

    border-radius: 4px;
    background: Theme.card_bg.with-alpha(92%);

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: root.title;
            color: Theme.accent;
            font-size: 12px;
            font-weight: 700;
        }

        HorizontalLayout {
            spacing: 10px;
            alignment: start;

            Text {
                text: root.version-text;
                color: Theme.label;
                font-size: 12.5px;
                vertical-alignment: center;
            }

            if root.show-update-badge: Rectangle {
                height: 24px;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.accent.with-alpha(72%);
                background: Theme.accent-soft.with-alpha(56%);

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    alignment: center;

                    Text {
                        text: Tr.about-update-available + " · " + root.latest-version-text;
                        color: Theme.text;
                        font-size: 11px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component IconActionButton inherits Rectangle {
    in property <image> icon;
    in property <length> button-size: 34px;
    callback clicked();

    width: root.button-size;
    height: root.button-size;
    border-radius: 4px;
    border-width: 1px;
    border-color: touch.has-hover ? Theme.accent.with-alpha(56%) : Theme.border.with-alpha(68%);
    background: touch.has-hover ? Theme.surface.with-alpha(72%) : Theme.card_bg.with-alpha(92%);

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: root.button-size - 16px;
        height: root.button-size - 16px;
        source: root.icon;
        image-fit: contain;
        colorize: touch.has-hover ? Theme.accent : Theme.label;
    }

    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            root.clicked();
        }
    }
}

export component AboutWindow inherits Window {
    title: Tr.about-window-title;
    icon: @image-url("../../assets/icon.svg");
    background: Theme.bg;
    preferred-width: 720px;
    preferred-height: 500px;
    default-font-family: "Miranda Sans";
    default-font-size: 14px;

    in property <string> version-text: "";
    in property <bool> show-update-badge: false;
    in property <string> latest-version-text: "";

    callback closed();
    callback open-github();
    callback open-x();

    VerticalLayout {
        padding: 22px;
        spacing: 16px;

        HorizontalLayout {
            alignment: end;

            IconActionButton {
                button-size: 30px;
                icon: @image-url("../../assets/ui-icons/thumbnail-close.svg");
                clicked => {
                    root.closed();
                }
            }
        }

        HorizontalLayout {
            spacing: 20px;
            alignment: start;

            Rectangle {
                width: 250px;
                min-height: 360px;
                border-radius: 4px;
                background: Theme.card_bg.with-alpha(92%);

                VerticalLayout {
                    padding: 16px;
                    spacing: 14px;
                    alignment: center;

                    Image {
                        source: @image-url("../../assets/disk.webp");
                        width: 250px;
                        height: 250px;
                        image-fit: contain;
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        alignment: center;

                        IconActionButton {
                            icon: @image-url("../../assets/ui-icons/social-github.svg");
                            clicked => {
                                root.open-github();
                            }
                        }

                        IconActionButton {
                            icon: @image-url("../../assets/ui-icons/social-x.svg");
                            clicked => {
                                root.open-x();
                            }
                        }
                    }
                }
            }

            VerticalLayout {
                spacing: 12px;
                vertical-stretch: 1;

                Text {
                    text: Tr.about-title;
                    color: Theme.text;
                    font-size: 28px;
                    font-weight: 800;
                    wrap: word-wrap;
                }

                Text {
                    text: Tr.about-subtitle;
                    color: Theme.muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                VersionCard {
                    title: Tr.about-version-title;
                    version-text: root.version-text;
                    show-update-badge: root.show-update-badge;
                    latest-version-text: root.latest-version-text;
                }

                AboutCard {
                    title: Tr.about-credits-title;
                    body: Tr.about-credits-body;
                    vertical-stretch: 1;
                }
            }
        }
    }
}
