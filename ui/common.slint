import "../assets/fonts/MirandaSans-Regular.ttf";
import "../assets/fonts/MirandaSans-Medium.ttf";
import "../assets/fonts/MirandaSans-SemiBold.ttf";
import "../assets/fonts/MirandaSans-Bold.ttf";
import "../assets/fonts/MirandaSans-Italic.ttf";
import "../assets/fonts/MirandaSans-MediumItalic.ttf";
import "../assets/fonts/MirandaSans-SemiBoldItalic.ttf";
import "../assets/fonts/MirandaSans-BoldItalic.ttf";

// Shared globals, theme tokens, and view-model structs for Panopticon.

export global Tr {
    // App identity
    in property <string> app-name: "Panopticon";
    in property <string> main-window-title: "Panopticon";
    in property <string> settings-window-title: "Panopticon — Settings";
    in property <string> tag-window-title: "Panopticon — Create tag";
    in property <string> about-window-title: "Panopticon — About";

    // ThumbnailCard
    in property <string> minimized: "minimized";
    in property <string> last-seen: "LAST SEEN";

    // Status bar
    in property <string> visible-label: "visible";
    in property <string> hidden-label: "hidden";
    in property <string> always-on-top-label: "always on top";
    in property <string> normal-window-label: "normal window";
    in property <string> toolbar-hint: "right-click status bar / M: menu | Esc exit";
    in property <string> anim-on: "anim on";
    in property <string> anim-off: "anim off";

    // Layout options
    in property <string> layout-grid-label: "Grid";
    in property <string> layout-mosaic-label: "Mosaic";
    in property <string> layout-bento-label: "Bento";
    in property <string> layout-fibonacci-label: "Fibonacci";
    in property <string> layout-columns-label: "Columns";
    in property <string> layout-row-label: "Row";
    in property <string> layout-column-label: "Column";
    in property <[string]> layout-options: [
        layout-grid-label,
        layout-mosaic-label,
        layout-bento-label,
        layout-fibonacci-label,
        layout-columns-label,
        layout-row-label,
        layout-column-label,
    ];

    // Grouping options
    in property <string> group-none-label: "No grouping";
    in property <string> group-application-label: "Application";
    in property <string> group-monitor-label: "Monitor";
    in property <string> group-title-label: "Window title";
    in property <string> group-class-label: "Window class";
    in property <[string]> group-options: [
        group-none-label,
        group-application-label,
        group-monitor-label,
        group-title-label,
        group-class-label,
    ];

    // Dock options
    in property <string> dock-none-label: "Floating (no dock)";
    in property <string> dock-left-label: "Left";
    in property <string> dock-right-label: "Right";
    in property <string> dock-top-label: "Top";
    in property <string> dock-bottom-label: "Bottom";
    in property <[string]> dock-options: [
        dock-none-label,
        dock-left-label,
        dock-right-label,
        dock-top-label,
        dock-bottom-label,
    ];

    // Locale options
    in property <string> locale-english-label: "English";
    in property <string> locale-spanish-label: "Spanish";
    in property <[string]> language-options: [locale-english-label, locale-spanish-label];

    // Image fit options
    in property <string> fit-cover-label: "Cover";
    in property <string> fit-contain-label: "Contain";
    in property <string> fit-fill-label: "Fill";
    in property <string> fit-preserve-label: "Preserve";
    in property <[string]> image-fit-options: [
        fit-cover-label,
        fit-contain-label,
        fit-fill-label,
        fit-preserve-label,
    ];

    // Dynamic filter defaults
    in property <string> all-monitors-label: "All monitors";
    in property <string> all-tags-label: "All tags";
    in property <string> all-apps-label: "All applications";
    in property <string> no-hidden-label: "No hidden apps";
    in property <string> no-saved-profiles-label: "No saved workspaces";
    in property <string> default-profile-label: "default";

    // Empty state
    in property <string> empty-message: "No windows available to preview";
    in property <string> empty-helper: "Open or restore any desktop window.\nPanopticon will keep watching from the tray.";

    // Shared actions
    in property <string> action-close: "Close";
    in property <string> action-reset-defaults: "Reset defaults";
    in property <string> action-restore-selected: "Restore selected";
    in property <string> action-restore-all: "Restore all";
    in property <string> action-browse-image: "Browse image…";
    in property <string> action-clear-image: "Clear image";
    in property <string> action-refresh-now: "Refresh now";
    in property <string> action-check-updates: "Check updates";
    in property <string> action-auto-apply: "Changes apply automatically.";
    in property <string> action-about: "About";
    in property <string> action-load-profile: "Load workspace";

    // About window
    in property <string> about-title: "About Panopticon";
    in property <string> about-subtitle: "A native Windows dashboard for exploring open windows through live DWM thumbnails.";
    in property <string> about-version-title: "Version";
    in property <string> about-update-available: "Update available";
    in property <string> about-description-title: "Application";
    in property <string> about-description-body: "Panopticon helps you preview, organize, and activate live desktop windows from a single local control room.";
    in property <string> about-credits-title: "Credits";
    in property <string> about-credits-body: "Created by gvastethecreator.\nBuilt with Rust, Slint, windows-rs, and the Desktop Window Manager thumbnail APIs.\nUI icons by HugeIcons.\nLicense: MIT.";

    // Settings hints already used from Rust
    in property <string> dock-mode-hint: "In dock mode this option is automatically disabled.";
    in property <string> filters-hint: "Filters and grouping are also reflected in the status bar and reorder visible cells.";
    in property <string> current-profile-prefix: "Current workspace: ";
    in property <string> profile-input-label: "Workspace:";
    in property <string> save-profile-btn: "Save workspace";
    in property <string> open-instance-btn: "Open another instance";
    in property <string> no-hidden-hint: "No hidden apps to restore right now.";

    // Settings window chrome
    in property <string> settings-title: "Settings";
    in property <string> settings-subtitle: "Customize the dashboard, backgrounds, shortcuts, and overall behavior.";
    in property <string> settings-profile-badge: "Workspace";

    // Sidebar navigation
    in property <string> settings-nav-behaviour-display-title: "Behaviour & Display";
    in property <string> settings-nav-behaviour-display-subtitle: "Window behaviour, tray and visible chrome";
    in property <string> settings-nav-filters-title: "Filters";
    in property <string> settings-nav-filters-subtitle: "Monitor, tag, app and hidden-state tools";
    in property <string> settings-nav-theme-background-title: "Theme & Background";
    in property <string> settings-nav-theme-background-subtitle: "Theme presets, solid canvas colour and image";
    in property <string> settings-nav-profiles-title: "Workspaces";
    in property <string> settings-nav-profiles-subtitle: "Save and launch named setups";
    in property <string> settings-nav-shortcuts-title: "Keyboard Shortcuts";
    in property <string> settings-nav-shortcuts-subtitle: "Customize the dashboard key map";
    in property <string> settings-nav-advanced-title: "Advanced Options";
    in property <string> settings-nav-advanced-subtitle: "Refresh cadence and manual runtime tools";

    // Behaviour page
    in property <string> settings-page-behaviour-display-title: "Behaviour & Display";
    in property <string> settings-page-behaviour-display-subtitle: "Adjust how the main window behaves, what information is shown, and how it responds to the tray.";
    in property <string> settings-section-behaviour-title: "Behaviour";
    in property <string> settings-section-behaviour-helper: "Each option includes a small summary so you do not have to guess what it does.";
    in property <string> settings-option-language-title: "Language";
    in property <string> settings-option-language-description: "Choose the application language. English is the default; Spanish is also available.";
    in property <string> settings-option-always-on-top-title: "Always on top";
    in property <string> settings-option-always-on-top-description: "Keep Panopticon above other windows even while switching applications.";
    in property <string> settings-option-animate-transitions-title: "Animate transitions";
    in property <string> settings-option-animate-transitions-description: "Smooth layout changes, filters, and visual reordering between thumbnails.";
    in property <string> settings-option-minimize-to-tray-title: "Minimize to tray";
    in property <string> settings-option-minimize-to-tray-description: "When minimized, hide the app from the desktop while keeping it alive in the system tray.";
    in property <string> settings-option-close-to-tray-title: "Close to tray";
    in property <string> settings-option-close-to-tray-description: "Interpret the window close button as hiding to the tray instead of exiting.";
    in property <string> settings-option-preserve-aspect-ratio-title: "Preserve aspect ratio by default";
    in property <string> settings-option-preserve-aspect-ratio-description: "New applications will better respect the original proportion of their thumbnails.";
    in property <string> settings-option-hide-on-select-title: "Hide after selecting an app";
    in property <string> settings-option-hide-on-select-description: "Hide Panopticon when you activate a window from the dashboard.";
    in property <string> settings-option-start-in-tray-title: "Start hidden in tray";
    in property <string> settings-option-start-in-tray-description: "Launch directly in the background for a quieter startup.";
    in property <string> settings-option-run-at-startup-title: "Run at startup";
    in property <string> settings-option-run-at-startup-description: "Register Panopticon in the current Windows session so it launches automatically when you sign in.";
    in property <string> settings-option-lock-layout-title: "Lock layout changes";
    in property <string> settings-option-lock-layout-description: "Prevent layout changes from the keyboard or the application menu.";
    in property <string> settings-option-lock-cell-resize-title: "Lock cell resizing";
    in property <string> settings-option-lock-cell-resize-description: "Disable separator dragging to protect the current composition.";
    in property <string> settings-section-display-title: "Display";
    in property <string> settings-section-display-helper: "Controls for layout-at-startup, dock placement, sizing, and dashboard readability.";
    in property <string> toolbar-position-top-label: "Top";
    in property <string> toolbar-position-bottom-label: "Bottom";
    in property <[string]> toolbar-position-options: [toolbar-position-top-label, toolbar-position-bottom-label];
    in property <string> settings-option-show-toolbar-title: "Show status bar";
    in property <string> settings-option-show-toolbar-description: "Show the dashboard status bar with status summary and quick access to the menu.";
    in property <string> settings-option-toolbar-position-title: "Status bar position";
    in property <string> settings-option-toolbar-position-description: "Choose whether the status bar stays at the top or bottom of the dashboard.";
    in property <string> settings-option-show-info-title: "Show window info above thumbnails";
    in property <string> settings-option-show-info-description: "Add the window and application name above each preview for quick context.";
    in property <string> settings-option-show-app-icons-title: "Show app icons in cells";
    in property <string> settings-option-show-app-icons-description: "Render the process icon inside each cell to identify apps faster.";

    // Filters page
    in property <string> settings-page-filters-title: "Filters";
    in property <string> settings-page-filters-subtitle: "Limit the dashboard by monitor, tags, applications, or groups, and restore hidden apps without leaving this view.";
    in property <string> settings-option-monitor-filter-title: "Monitor filter";
    in property <string> settings-option-monitor-filter-description: "Limit the dashboard to a specific monitor when working with multiple displays.";
    in property <string> settings-option-tag-filter-title: "Tag filter";
    in property <string> settings-option-tag-filter-description: "Show only applications associated with a specific manual tag.";
    in property <string> settings-option-app-filter-title: "Application filter";
    in property <string> settings-option-app-filter-description: "Isolate a specific app when you want to review only its window group.";
    in property <string> settings-option-group-windows-title: "Group windows by";
    in property <string> settings-option-group-windows-description: "Visually reorder the list without filtering content, which is ideal for spotting patterns.";
    in property <string> settings-section-hidden-apps-title: "Hidden applications";
    in property <string> settings-section-hidden-apps-helper: "Restore hidden apps one by one or all at once from persisted state.";
    in property <string> settings-section-app-rules-title: "App Rules Manager";
    in property <string> settings-section-app-rules-helper: "Edit per-app rules for visibility, aspect ratio, hide-on-select, refresh mode, tags, and color.";
    in property <string> settings-option-app-rules-app-title: "Application";
    in property <string> settings-option-app-rules-app-description: "Includes running apps and apps with saved rules.";
    in property <string> settings-option-app-rules-search-placeholder: "Search by app, id, or tags...";
    in property <string> settings-app-rules-filter-all-label: "All apps";
    in property <string> settings-app-rules-filter-running-label: "Running apps";
    in property <string> settings-app-rules-filter-saved-label: "Saved rules only";
    in property <string> settings-app-rules-filter-hidden-label: "Hidden apps";
    in property <string> settings-app-rules-filter-tagged-label: "Tagged apps";
    in property <string> settings-app-rules-filter-refresh-label: "Custom refresh";
    in property <string> settings-app-rules-filter-pinned-label: "Pinned apps";
    in property <[string]> settings-app-rules-filter-options: [
        settings-app-rules-filter-all-label,
        settings-app-rules-filter-running-label,
        settings-app-rules-filter-saved-label,
        settings-app-rules-filter-hidden-label,
        settings-app-rules-filter-tagged-label,
        settings-app-rules-filter-refresh-label,
        settings-app-rules-filter-pinned-label,
    ];
    in property <string> settings-app-rules-active-title: "Active rule";
    in property <string> settings-app-rules-active-badge: "APP RULE";
    in property <string> settings-app-rules-hidden-title: "Hide app in dashboard";
    in property <string> settings-app-rules-hidden-description: "When enabled, this app does not appear in the main grid.";
    in property <string> settings-app-rules-preserve-aspect-title: "Preserve aspect ratio";
    in property <string> settings-app-rules-preserve-aspect-description: "Per-app override for the global aspect setting.";
    in property <string> settings-app-rules-hide-on-select-title: "Hide Panopticon on select";
    in property <string> settings-app-rules-hide-on-select-description: "Per-app override for hide-on-select behavior.";
    in property <string> settings-app-rules-refresh-mode-title: "Thumbnail refresh mode";
    in property <string> settings-app-rules-refresh-mode-description: "Realtime, Frozen, or Interval.";
    in property <string> settings-app-rules-refresh-realtime-label: "Realtime";
    in property <string> settings-app-rules-refresh-frozen-label: "Frozen";
    in property <string> settings-app-rules-refresh-interval-label: "Interval";
    in property <[string]> settings-app-rules-refresh-options: [
        settings-app-rules-refresh-realtime-label,
        settings-app-rules-refresh-frozen-label,
        settings-app-rules-refresh-interval-label,
    ];
    in property <string> settings-app-rules-interval-title: "Interval (ms)";
    in property <string> settings-app-rules-interval-description: "Applied only when mode is Interval.";
    in property <string> settings-app-rules-tags-title: "Tags (CSV)";
    in property <string> settings-app-rules-tags-description: "Example: work, browser, stream";
    in property <string> settings-app-rules-tags-placeholder: "work, browser";
    in property <string> settings-app-rules-tags-helper: "Add tags one by one and remove them with a click.";
    in property <string> settings-app-rules-tag-add-button: "Add tag";
    in property <string> settings-app-rules-tag-remove-hint: "Click a chip to remove it.";
    in property <string> settings-app-rules-tag-suggestions-title: "Quick suggestions";
    in property <string> settings-app-rules-tag-suggestion-work: "work";
    in property <string> settings-app-rules-tag-suggestion-browser: "browser";
    in property <string> settings-app-rules-tag-suggestion-dev: "dev";
    in property <string> settings-app-rules-tag-suggestion-stream: "stream";
    in property <[string]> settings-app-rules-tag-suggestion-options: [
        settings-app-rules-tag-suggestion-work,
        settings-app-rules-tag-suggestion-browser,
        settings-app-rules-tag-suggestion-dev,
        settings-app-rules-tag-suggestion-stream,
    ];
    in property <string> settings-app-rules-color-title: "Hex color (optional)";
    in property <string> settings-app-rules-color-description: "Use RRGGBB format, or empty to clear override.";
    in property <string> settings-app-rules-color-placeholder: "5CA9FF";
    in property <string> settings-app-rules-apply-button: "Apply rule";
    in property <string> settings-app-rules-reset-button: "Reset rule";
    in property <string> settings-app-rules-clear-unused-button: "Clear inactive rules";
    in property <string> settings-app-rules-no-selection: "Select an application to edit its rule.";
    in property <string> settings-app-rules-select-option: "Select application rule…";
    in property <string> settings-app-rules-cleanup-none: "No inactive rules to clean.";
    in property <string> settings-app-rules-cleanup-count: "{} inactive rules can be cleaned.";

    // Theme page
    in property <string> settings-page-theme-background-title: "Theme & Background";
    in property <string> settings-page-theme-background-subtitle: "Pick a theme preset, fine-tune core colours, and combine it with a custom canvas colour and background image.";
    in property <string> settings-section-theme-grid-title: "Themes";
    in property <string> settings-section-theme-grid-helper: "Pick a preset from a compact list; the theme defines accents, panels, and overall contrast.";
    in property <string> settings-section-theme-colours-title: "Theme colors";
    in property <string> settings-section-theme-colours-helper: "Adjust core colors of the active theme. Leave a field empty to keep the preset value.";
    in property <string> settings-section-canvas-background-title: "Canvas background";
    in property <string> settings-section-canvas-background-helper: "The canvas color sits behind the cards and the optional background image.";
    in property <string> settings-option-custom-canvas-colour-title: "Background";
    in property <string> settings-option-custom-canvas-colour-description: "Enter a manual RGB hex value if you want a color outside the quick palette.";
    in property <string> settings-option-rgb-picker-title: "RGB color picker";
    in property <string> settings-channel-red-label: "R";
    in property <string> settings-channel-green-label: "G";
    in property <string> settings-channel-blue-label: "B";
    in property <string> settings-theme-accent-label: "Accent";
    in property <string> settings-theme-surface-label: "Surface";
    in property <string> settings-theme-card-label: "Card";
    in property <string> settings-theme-text-label: "Text";
    in property <string> settings-theme-muted-label: "Muted";
    in property <string> settings-theme-border-label: "Border";
    in property <string> settings-theme-override-hint: "Leave blank to inherit the current preset colour.";
    in property <string> settings-section-preview-title: "Preview";
    in property <string> settings-section-preview-helper: "Quick summary of the active background with colour and optional image.";
    in property <string> settings-section-background-image-title: "Background image";
    in property <string> settings-section-background-image-helper: "Place an image behind the dashboard and define how it should fit within the canvas.";
    in property <string> settings-option-image-file-title: "Image file";
    in property <string> settings-option-image-file-description: "You can paste a path manually or choose it with the native picker.";
    in property <string> settings-option-image-fit-title: "Image fit";
    in property <string> settings-option-image-fit-description: "Control whether the image covers, contains, or fills the visible dashboard area.";
    in property <string> settings-option-image-opacity-title: "Image opacity";
    in property <string> settings-option-image-opacity-description: "Control how strong the background image should appear over the canvas colour.";

    // Workspaces page
    in property <string> settings-page-profiles-title: "Workspaces";
    in property <string> settings-page-profiles-subtitle: "Save complete combinations of settings and open new instances already pointed at the workspace you want.";
    in property <string> settings-section-edit-profile-title: "Edit workspace";
    in property <string> settings-section-edit-profile-helper: "Use a short, descriptive name to save or open the current snapshot in another instance.";
    in property <string> settings-current-profile-card-title: "Current workspace";
    in property <string> settings-option-profile-name-title: "Workspace name";
    in property <string> settings-option-profile-name-description: "Name used to save this setup or launch another instance with it.";
    in property <string> settings-section-saved-profiles-title: "Saved workspaces";
    in property <string> settings-section-saved-profiles-helper: "Summary of detected workspaces plus a reminder of the recommended multi-instance workflow.";
    in property <string> settings-section-load-profile-title: "Switch current instance";
    in property <string> settings-section-load-profile-helper: "Load another saved workspace into this running Panopticon window.";
    in property <string> settings-option-available-profile-title: "Available workspaces";
    in property <string> settings-option-available-profile-description: "Choose which saved workspace this instance should load right now.";
    in property <string> settings-tips-title: "Tips";
    in property <string> settings-tips-body: "- Save the current workspace first if you are about to open another instance.\n- Use simple names like work, stream, or review.\n- Theme, background, and shortcut settings travel with the workspace.";

    // Shortcuts page
    in property <string> settings-page-shortcuts-title: "Keyboard Shortcuts";
    in property <string> settings-page-shortcuts-subtitle: "Dashboard shortcuts use a single key; global activation accepts Ctrl / Alt / Shift plus a key like P or Space.";
    in property <string> settings-section-layout-bindings-title: "Layout bindings";
    in property <string> settings-section-layout-bindings-helper: "Direct assignments for specific layouts, reset, and the general cycle action.";
    in property <string> settings-shortcut-layout-grid-title: "Grid layout";
    in property <string> settings-shortcut-layout-grid-description: "Switch to the Grid view instantly.";
    in property <string> settings-shortcut-layout-mosaic-title: "Mosaic layout";
    in property <string> settings-shortcut-layout-mosaic-description: "Switch to the Mosaic layout.";
    in property <string> settings-shortcut-layout-bento-title: "Bento layout";
    in property <string> settings-shortcut-layout-bento-description: "Activate the Bento layout.";
    in property <string> settings-shortcut-layout-fibonacci-title: "Fibonacci layout";
    in property <string> settings-shortcut-layout-fibonacci-description: "Open the Fibonacci composition.";
    in property <string> settings-shortcut-layout-columns-title: "Columns layout";
    in property <string> settings-shortcut-layout-columns-description: "Activate Columns.";
    in property <string> settings-shortcut-layout-row-title: "Row layout";
    in property <string> settings-shortcut-layout-row-description: "Activate the Row view.";
    in property <string> settings-shortcut-layout-column-title: "Column layout";
    in property <string> settings-shortcut-layout-column-description: "Activate the Column view.";
    in property <string> settings-shortcut-reset-layout-title: "Reset Layout";
    in property <string> settings-shortcut-reset-layout-description: "Reset custom proportions for the current layout.";
    in property <string> settings-shortcut-cycle-layout-title: "Cycle layout";
    in property <string> settings-shortcut-cycle-layout-description: "Advance to the next layout in the internal sequence.";
    in property <string> settings-section-dashboard-actions-title: "Dashboard actions";
    in property <string> settings-section-dashboard-actions-helper: "Shortcuts for opening panels, refreshing state, and toggling visible options.";
    in property <string> settings-shortcut-cycle-theme-title: "Cycle theme";
    in property <string> settings-shortcut-cycle-theme-description: "Press T for the next theme or Shift+T for the previous one.";
    in property <string> settings-shortcut-toggle-animations-title: "Toggle animations";
    in property <string> settings-shortcut-toggle-animations-description: "Enable or disable dashboard transitions.";
    in property <string> settings-shortcut-toggle-toolbar-title: "Toggle status bar";
    in property <string> settings-shortcut-toggle-toolbar-description: "Show or hide the dashboard's bottom status bar.";
    in property <string> settings-shortcut-toggle-window-info-title: "Toggle window info";
    in property <string> settings-shortcut-toggle-window-info-description: "Show or hide titles and info above thumbnails.";
    in property <string> settings-shortcut-toggle-always-on-top-title: "Toggle always on top";
    in property <string> settings-shortcut-toggle-always-on-top-description: "Toggle the always-on-top mode above other apps.";
    in property <string> settings-shortcut-open-settings-title: "Open settings";
    in property <string> settings-shortcut-open-settings-description: "Open this window from the main dashboard.";
    in property <string> settings-shortcut-open-menu-title: "Open application menu";
    in property <string> settings-shortcut-open-menu-description: "Open the main native menu with quick actions.";
    in property <string> settings-shortcut-open-command-palette-title: "Open command palette";
    in property <string> settings-shortcut-open-command-palette-description: "Open the quick command search panel.";
    in property <string> settings-shortcut-global-activate-title: "Activate Panopticon globally";
    in property <string> settings-shortcut-global-activate-description: "Bring Panopticon to the foreground from anywhere. Leave empty to disable it.";
    in property <string> settings-shortcut-refresh-now-title: "Refresh now";
    in property <string> settings-shortcut-refresh-now-description: "Force a new window enumeration and refresh the dashboard.";
    in property <string> settings-shortcut-exit-app-title: "Exit app";
    in property <string> settings-shortcut-exit-app-description: "Close Panopticon from the keyboard.";
    in property <string> settings-shortcut-alt-toolbar-title: "Use Alt as a quick status bar toggle";
    in property <string> settings-shortcut-alt-toolbar-description: "Keep the legacy Windows shortcut to hide or show the status bar with a single Alt press.";

    // Advanced page
    in property <string> settings-page-advanced-title: "Advanced Options";
    in property <string> settings-page-advanced-subtitle: "Manual refresh/update controls and the base cadence used for background window discovery.";
    in property <string> settings-option-default-layout-title: "Default layout";
    in property <string> settings-option-default-layout-description: "Choose which layout Panopticon should use each time this workspace starts.";
    in property <string> settings-option-default-layout-docked-description: "Dock mode automatically uses Column on the sides and Row on the top or bottom, so this selector only applies while floating.";
    in property <string> settings-option-refresh-interval-title: "Refresh interval";
    in property <string> settings-option-refresh-interval-description: "Base cadence for enumerating windows and refreshing the dashboard when you do not force a manual refresh.";
    in property <string> settings-refresh-mode-realtime-label: "Realtime";
    in property <string> settings-refresh-mode-balanced-label: "Balanced";
    in property <string> settings-refresh-mode-battery-saver-label: "Battery Saver";
    in property <string> settings-refresh-mode-manual-label: "Manual";
    in property <string> settings-section-refresh-performance-title: "Refresh performance mode";
    in property <string> settings-section-refresh-performance-helper: "Realtime/Balanced/Battery Saver set cadence automatically. Manual uses the explicit interval below.";
    in property <string> settings-option-refresh-performance-mode-title: "Refresh performance mode";
    in property <string> settings-option-refresh-performance-mode-description: "Global cadence workspace for window discovery and refresh.";
    in property <string> settings-refresh-active-mode-title: "Active mode";
    in property <string> settings-refresh-active-mode-realtime: "Realtime (1s)";
    in property <string> settings-refresh-active-mode-balanced: "Balanced (2s)";
    in property <string> settings-refresh-active-mode-battery: "Battery Saver (5s)";
    in property <string> settings-refresh-active-mode-manual: "Manual (uses explicit interval)";
    in property <[string]> settings-refresh-mode-options: [
        settings-refresh-mode-realtime-label,
        settings-refresh-mode-balanced-label,
        settings-refresh-mode-battery-saver-label,
        settings-refresh-mode-manual-label,
    ];
    in property <[string]> settings-refresh-interval-options: ["1s", "2s", "5s", "10s"];
    in property <string> settings-section-manual-refresh-title: "Manual refresh";
    in property <string> settings-section-manual-refresh-helper: "Use this section to force a window refresh or to check for updates immediately.";
    in property <string> settings-section-dock-thickness-title: "Dock thickness";
    in property <string> settings-section-dock-thickness-helper: "For a side dock, width is used; for top/bottom, height is used. Values are clamped to safe minimums.";
    in property <string> settings-section-floating-window-size-title: "Floating window size";
    in property <string> settings-section-floating-window-size-helper: "When dock mode is disabled, these values track the floating window size and are clamped to safe minimums.";
    in property <string> settings-option-thumbnail-render-scale-title: "Thumbnail render scale";
    in property <string> settings-option-thumbnail-render-scale-description: "Lower values reduce thumbnail rendering size to improve performance, at the cost of preview sharpness.";
    in property <string> settings-width-label: "Width";
    in property <string> settings-height-label: "Height";
    in property <string> settings-version-label: "Panopticon";
    in property <string> settings-option-dock-position-title: "Dock position";
    in property <string> settings-option-dock-position-description: "Turn the window into a docked appbar or leave it floating as a free panel.";

    // Tag dialog
    in property <string> tag-title: "Create custom tag";
    in property <string> tag-app-label: "Application: ";
    in property <string> tag-name-label: "Tag name";
    in property <string> tag-preset-colour: "Preset colour";
    in property <string> tag-create-assign: "Create and assign";
    in property <string> tag-colour-amber-label: "Amber";
    in property <string> tag-colour-sky-label: "Sky";
    in property <string> tag-colour-mint-label: "Mint";
    in property <string> tag-colour-rose-label: "Rose";
    in property <string> tag-colour-violet-label: "Violet";
    in property <string> tag-colour-sun-label: "Sun";
    in property <[string]> tag-colour-options: [
        tag-colour-amber-label,
        tag-colour-sky-label,
        tag-colour-mint-label,
        tag-colour-rose-label,
        tag-colour-violet-label,
        tag-colour-sun-label,
    ];
}

export global Theme {
    in-out property <color> bg:           #181513;
    in-out property <color> toolbar-bg:   #1a1814;
    in-out property <color> panel-bg:     #2A2522;
    in-out property <color> card-bg:      #1e1c1a;
    in-out property <color> border:       #3a3530;
    in-out property <color> accent:       #D29A5C;
    in-out property <color> accent-soft:  #5C4A38;
    in-out property <color> text:         #E6E2DE;
    in-out property <color> label:        #C8C1BA;
    in-out property <color> muted:        #8D867F;
    in-out property <color> hover-border: #D29A5C;
    in-out property <color> placeholder:  #141210;
    in-out property <color> footer-bg:    #1a1814;
    in-out property <color> surface:      #221E1C;
    in-out property <bool> dark-scheme:   true;
}

export struct ThumbnailData {
    x: float,
    y: float,
    width: float,
    height: float,
    title: string,
    app-label: string,
    is-active: bool,
    accent-color: color,
    show-footer: bool,
    is-minimized: bool,
    icon: image,
    show-icon: bool,
    pinned-slot: int,
}

export struct ResizeHandleData {
    x: float,
    y: float,
    width: float,
    height: float,
    horizontal: bool,
    index: int,
}

export struct ThemePreviewData {
    index: int,
    label: string,
    subtitle: string,
    bg: color,
    surface: color,
    accent: color,
    text: color,
}
